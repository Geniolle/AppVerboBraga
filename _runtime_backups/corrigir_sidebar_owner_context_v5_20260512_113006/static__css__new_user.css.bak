/* APPVERBO_TABLE_PAGINATION_SECOND_IMAGE_V2_END */
/* APPVERBO_ADMIN_USER_FORM_3_COLUMNS_V1_START */
/* Subprocesso Utilizador: usa 3 campos por linha para ganhar espaço visual. */

#create-user-card .grid,
#edit-user-card .grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

#create-user-card .field,
#edit-user-card .field {
  min-width: 0;
}

#create-user-card .field.full,
#edit-user-card .field.full {
  grid-column: auto;
}

#create-user-card input,
#create-user-card select,
#edit-user-card input,
#edit-user-card select {
  width: 100%;
  min-width: 0;
}

@media (max-width: 1200px) {
  #create-user-card .grid,
  #edit-user-card .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 760px) {
  #create-user-card .grid,
  #edit-user-card .grid {
    grid-template-columns: 1fr;
  }
}
/* APPVERBO_ADMIN_USER_FORM_3_COLUMNS_V1_END */

/* APPVERBO_SAVE_CANCEL_BUTTON_STANDARD_V1_START */

:root {
  --appverbo-save-cancel-button-width-v1: 112px;
  --appverbo-save-cancel-button-height-v1: 38px;
}

.action-btn,
.action-btn-cancel,
button.action-btn,
button.action-btn-cancel,
input.action-btn,
input.action-btn-cancel,
.profile-edit-actions > button[type="submit"],
.profile-edit-actions > .profile-cancel-btn,
.form-action-row > button[type="submit"],
.form-action-row > .action-btn,
.form-action-row > .action-btn-cancel,
.appverbo-sidebar-sections-footer-v2 > .action-btn,
.appverbo-sidebar-sections-footer-v2 > .action-btn-cancel {
  min-width: var(--appverbo-save-cancel-button-width-v1) !important;
  width: var(--appverbo-save-cancel-button-width-v1) !important;
  height: var(--appverbo-save-cancel-button-height-v1) !important;
  min-height: var(--appverbo-save-cancel-button-height-v1) !important;
  padding: 0 14px !important;
  box-sizing: border-box !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  line-height: 1 !important;
  white-space: nowrap !important;
  text-align: center !important;
  font-weight: 700 !important;
}

.profile-edit-actions,
.form-action-row,
.entity-form-actions,
.appverbo-sidebar-sections-footer-v2 {
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 8px !important;
}

.appverbo-sidebar-sections-footer-v2 .appverbo-sidebar-section-change-note-v2 {
  order: 3 !important;
  margin-left: 10px !important;
}

.appverbo-sidebar-sections-footer-v2 > .action-btn {
  order: 1 !important;
}

.appverbo-sidebar-sections-footer-v2 > .action-btn-cancel {
  order: 2 !important;
}

/* APPVERBO_SAVE_CANCEL_BUTTON_STANDARD_V1_END */

/* APPVERBO_CREATE_ENTRY_SEPARATE_BLOCK_V2_START */

.appverbo-create-entry-block-v1 {
  border: 1px solid #d5dceb;
  background: #f7faff;
  border-radius: 12px;
  padding: 16px;
  margin: 0 0 16px;
  box-sizing: border-box;
}

.entity-create-toolbar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 8px;
}

.entity-create-toolbar .action-btn,
.entity-create-toolbar .action-btn-secondary,
.appverbo-create-entry-toolbar-v1 .action-btn {
  align-self: flex-start;
}

/* APPVERBO_CREATE_ENTRY_SEPARATE_BLOCK_V2_END */

/* APPVERBO_CREATE_CARD_STANDARD_V4_START */

:root {
  --appverbo-create-card-background-v4: #f3f6fb;
  --appverbo-create-card-border-v4: #d5dceb;
  --appverbo-create-card-radius-v4: 12px;
  --appverbo-create-card-min-height-v4: 64px;
  --appverbo-create-card-padding-v4: 16px;
  --appverbo-create-card-margin-bottom-v4: 12px;
}

.appverbo-standard-create-card-v4,
.appverbo-sessoes-create-card-v3,
#admin-sidebar-sections-create-card {
  width: 100% !important;
  min-height: var(--appverbo-create-card-min-height-v4) !important;
  padding: var(--appverbo-create-card-padding-v4) !important;
  margin: 0 0 var(--appverbo-create-card-margin-bottom-v4) !important;
  border: 1px solid var(--appverbo-create-card-border-v4) !important;
  border-radius: var(--appverbo-create-card-radius-v4) !important;
  background: var(--appverbo-create-card-background-v4) !important;
  box-sizing: border-box !important;
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
}

.appverbo-standard-create-card-v4 > *,
.appverbo-sessoes-create-card-v3 > *,
#admin-sidebar-sections-create-card > * {
  flex: 0 0 auto;
}

.appverbo-standard-create-card-v4 .action-btn,
.appverbo-sessoes-create-card-v3 .action-btn,
#admin-sidebar-sections-create-card .action-btn {
  align-self: center !important;
}

.appverbo-sessoes-create-card-v3 .appverbo-create-entry-block-v1,
#admin-sidebar-sections-create-card .appverbo-create-entry-block-v1 {
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  border: 0 !important;
  background: transparent !important;
  border-radius: 0 !important;
  box-sizing: border-box !important;
}

.appverbo-sessoes-create-card-v3 .appverbo-create-entry-toolbar-v1,
#admin-sidebar-sections-create-card .appverbo-create-entry-toolbar-v1 {
  min-height: 32px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 8px !important;
}

.appverbo-sessoes-create-card-v3 .appverbo-create-entry-panel-v1,
#admin-sidebar-sections-create-card .appverbo-create-entry-panel-v1 {
  width: 100% !important;
  margin-top: 14px !important;
  padding-top: 14px !important;
  border-top: 1px solid var(--appverbo-create-card-border-v4) !important;
}

/* APPVERBO_CREATE_CARD_STANDARD_V4_END */

/* APPVERBO_ANTI_FLICKER_V1_START */
/*
  Evita o "piscar" inicial da tela enquanto o JavaScript decide
  qual menu, aba e card devem ficar visiveis.
*/
body.appverbo-booting .content {
  visibility: hidden;
  opacity: 0;
}

body.appverbo-ready .content {
  visibility: visible;
  opacity: 1;
  transition: opacity 0.08s ease-in;
}

body.appverbo-local-navigation .content {
  transition: none;
}

body.appverbo-local-navigation .card {
  backface-visibility: hidden;
}

@media (prefers-reduced-motion: reduce) {
  body.appverbo-ready .content {
    transition: none;
  }
}
/* APPVERBO_ANTI_FLICKER_V1_END */

/* APPVERBO_REFRESH_SESSOES_VISIBILITY_V1_START */
/*
  Quando o contexto administrativo esta no subprocesso Sessoes,
  a Home nao deve ficar visivel no refresh.
*/
body.appverbo-admin-sessoes #home-summary-card {
  display: none !important;
}

body.appverbo-admin-sessoes .admin-subprocess-card-v1 {
  display: block;
}
/* APPVERBO_REFRESH_SESSOES_VISIBILITY_V1_END */

/* APPVERBO_ADMIN_PROCESS_ONLY_V1_START */
/*
  Estado desejado:
  - clique somente em Administrativo: mostra apenas o bloco central com subprocessos.
  - clique em Entidade, Utilizador, Sessoes ou Menu: mostra o conteudo do subprocesso.
*/
body.appverbo-admin-process-only #menu-tabs-card {
  display: block !important;
}

body.appverbo-admin-process-only .content .container > .card:not(#menu-tabs-card),
body.appverbo-admin-process-only .content .container > .admin-subprocess-card-v1 {
  display: none !important;
}

body.appverbo-admin-process-only #submenu-items .submenu-item.active,
body.appverbo-admin-process-only #submenu-items button.active,
body.appverbo-admin-process-only #submenu-items a.active {
  background: #f9fbff;
  border-color: #dce3f2;
  color: #2f3850;
}
/* APPVERBO_ADMIN_PROCESS_ONLY_V1_END */

/* APPVERBO_ADMIN_PROCESS_ONLY_CLEAR_ACTIVE_V1_START */
/*
  No clique somente no processo Administrativo, nenhum subprocesso deve ficar marcado.
  O !important e necessario porque outros modulos podem estilizar .active depois.
*/
body.appverbo-admin-process-only #submenu-items .active,
body.appverbo-admin-process-only #submenu-items [aria-selected="true"],
body.appverbo-admin-process-only #submenu-items .submenu-item.active,
body.appverbo-admin-process-only #submenu-items button.active,
body.appverbo-admin-process-only #submenu-items a.active,
body.appverbo-admin-process-only #submenu-items [data-admin-tab].active {
  background: #f9fbff !important;
  background-color: #f9fbff !important;
  border-color: #dce3f2 !important;
  color: #2f3850 !important;
  box-shadow: none !important;
  outline: none !important;
}

body.appverbo-admin-process-only #submenu-items .active::before,
body.appverbo-admin-process-only #submenu-items .active::after {
  display: none !important;
}
/* APPVERBO_ADMIN_PROCESS_ONLY_CLEAR_ACTIVE_V1_END */

/* APPVERBO_CLICK_FREE_SUBPROCESS_V1_START */
/*
  Enquanto o utilizador esta apenas no processo Administrativo,
  nenhuma aba de subprocesso deve ficar marcada e o clique em qualquer
  subprocesso deve poder abrir diretamente o destino correto.
*/
body.appverbo-admin-process-only #submenu-items .active,
body.appverbo-admin-process-only #submenu-items [aria-selected="true"],
body.appverbo-admin-process-only #submenu-items [data-active="true"],
body.appverbo-admin-process-only #submenu-items [data-selected="true"] {
  background: #f9fbff !important;
  background-color: #f9fbff !important;
  border-color: #dce3f2 !important;
  color: #2f3850 !important;
  box-shadow: none !important;
  outline: none !important;
}

body.appverbo-subprocess-direct-opening .content {
  opacity: 0.82;
}
/* APPVERBO_CLICK_FREE_SUBPROCESS_V1_END */

/* APPVERBO_ADMIN_SUBPROCESS_MENU_STABLE_V1_START */
/*
  O bloco superior dos subprocessos do Administrativo e sempre o mesmo.
  Durante a troca Entidade / Utilizador / Sessoes / Menu, ele nao deve sumir,
  piscar, mudar altura ou ser recriado visualmente. Somente a aba ativa muda.
*/
body.appverbo-admin-submenu-stable #menu-tabs-card,
body.appverbo-admin-subprocess-context #menu-tabs-card,
body.appverbo-admin-process-only #menu-tabs-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
  transform: none !important;
  transition: none !important;
  min-height: 62px;
  will-change: auto;
  contain: layout paint;
}

body.appverbo-admin-submenu-stable #submenu-items,
body.appverbo-admin-subprocess-context #submenu-items,
body.appverbo-admin-process-only #submenu-items {
  visibility: visible !important;
  opacity: 1 !important;
  transition: none !important;
}

body.appverbo-admin-submenu-switching #menu-tabs-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
  transition: none !important;
}

body.appverbo-admin-submenu-switching .content {
  transition: none !important;
}

body.appverbo-admin-process-only #submenu-items .active,
body.appverbo-admin-process-only #submenu-items [aria-selected="true"],
body.appverbo-admin-process-only #submenu-items [data-active="true"],
body.appverbo-admin-process-only #submenu-items [data-selected="true"] {
  background: #f9fbff !important;
  background-color: #f9fbff !important;
  border-color: #dce3f2 !important;
  color: #2f3850 !important;
  box-shadow: none !important;
  outline: none !important;
}
/* APPVERBO_ADMIN_SUBPROCESS_MENU_STABLE_V1_END */

/* APPVERBO_STANDARD_ADMIN_SUBPROCESS_BUTTONS_V1_START */
/*
  Padronizacao visual dos botoes do Administrativo.
  Mantem Entidade, Utilizador, Sessoes e Menu com o mesmo tamanho,
  e tambem normaliza botoes de criar, guardar, cancelar e acoes.
*/
:root {
  --appverbo-admin-tab-width-v1: 96px;
  --appverbo-admin-tab-height-v1: 38px;
  --appverbo-admin-action-height-v1: 42px;
  --appverbo-admin-action-min-width-v1: 132px;
  --appverbo-admin-button-radius-v1: 8px;
  --appverbo-admin-button-font-size-v1: 13px;
  --appverbo-admin-button-font-weight-v1: 700;
  --appverbo-admin-row-action-size-v1: 32px;
}

/* Menu superior dos subprocessos: Entidade, Utilizador, Sessoes, Menu */
#menu-tabs-card #submenu-items,
#menu-tabs-card .menu-tabs,
#submenu-items {
  align-items: center !important;
  gap: 6px !important;
}

#menu-tabs-card #submenu-items .submenu-item,
#menu-tabs-card #submenu-items button,
#menu-tabs-card #submenu-items a,
#menu-tabs-card #submenu-items [data-admin-tab],
#submenu-items .submenu-item,
#submenu-items button,
#submenu-items a,
#submenu-items [data-admin-tab] {
  width: var(--appverbo-admin-tab-width-v1) !important;
  min-width: var(--appverbo-admin-tab-width-v1) !important;
  max-width: var(--appverbo-admin-tab-width-v1) !important;
  height: var(--appverbo-admin-tab-height-v1) !important;
  min-height: var(--appverbo-admin-tab-height-v1) !important;
  max-height: var(--appverbo-admin-tab-height-v1) !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 10px !important;
  margin: 0 !important;
  border-radius: var(--appverbo-admin-button-radius-v1) !important;
  font-size: var(--appverbo-admin-button-font-size-v1) !important;
  font-weight: var(--appverbo-admin-button-font-weight-v1) !important;
  line-height: 1 !important;
  text-align: center !important;
  white-space: nowrap !important;
  text-decoration: none !important;
  box-sizing: border-box !important;
}

/* Botoes principais dos cards: Criar entidade, Criar sessao, Guardar, Cancelar */
.admin-subprocess-form-v1 button,
.admin-subprocess-form-v1 .action-btn,
.admin-subprocess-form-v1 .action-btn-cancel,
.admin-subprocess-actions-v1 button,
.admin-subprocess-actions-v1 a,
.admin-subprocess-create-collapse-v1 summary,
.entity-create-collapse summary,
.form-action-row button,
.form-action-row a,
button.action-btn,
a.action-btn,
.action-btn,
.action-btn-cancel {
  min-width: var(--appverbo-admin-action-min-width-v1) !important;
  height: var(--appverbo-admin-action-height-v1) !important;
  min-height: var(--appverbo-admin-action-height-v1) !important;
  max-height: var(--appverbo-admin-action-height-v1) !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 16px !important;
  margin-top: 0 !important;
  border-radius: var(--appverbo-admin-button-radius-v1) !important;
  font-size: var(--appverbo-admin-button-font-size-v1) !important;
  font-weight: var(--appverbo-admin-button-font-weight-v1) !important;
  line-height: 1 !important;
  text-align: center !important;
  white-space: nowrap !important;
  text-decoration: none !important;
  box-sizing: border-box !important;
}

/* Botoes pequenos de acoes nas tabelas */
.admin-subprocess-row-actions-v1 {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: flex-end !important;
  gap: 6px !important;
  white-space: nowrap !important;
}

.admin-subprocess-inline-form-v1 {
  display: inline-flex !important;
  align-items: center !important;
  margin: 0 !important;
}

.admin-subprocess-action-btn-v1,
.admin-subprocess-action-link-v1,
.admin-subprocess-row-actions-v1 button,
.admin-subprocess-row-actions-v1 a {
  width: var(--appverbo-admin-row-action-size-v1) !important;
  min-width: var(--appverbo-admin-row-action-size-v1) !important;
  max-width: var(--appverbo-admin-row-action-size-v1) !important;
  height: var(--appverbo-admin-row-action-size-v1) !important;
  min-height: var(--appverbo-admin-row-action-size-v1) !important;
  max-height: var(--appverbo-admin-row-action-size-v1) !important;
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  margin: 0 !important;
  border-radius: 7px !important;
  font-size: 14px !important;
  font-weight: 700 !important;
  line-height: 1 !important;
  text-align: center !important;
  text-decoration: none !important;
  box-sizing: border-box !important;
}

/* Evita que botoes de diferentes subprocessos mudem de altura por texto, icone ou fonte */
#menu-tabs-card button *,
#menu-tabs-card a *,
.admin-subprocess-action-btn-v1 *,
.admin-subprocess-action-link-v1 *,
.action-btn *,
.action-btn-cancel * {
  line-height: 1 !important;
}

/* Mantem o estado active visual, mas sem alterar tamanho */
#submenu-items .active,
#submenu-items [aria-selected="true"],
#submenu-items [data-active="true"] {
  width: var(--appverbo-admin-tab-width-v1) !important;
  min-width: var(--appverbo-admin-tab-width-v1) !important;
  max-width: var(--appverbo-admin-tab-width-v1) !important;
  height: var(--appverbo-admin-tab-height-v1) !important;
  min-height: var(--appverbo-admin-tab-height-v1) !important;
  max-height: var(--appverbo-admin-tab-height-v1) !important;
}

/* Responsivo: em telas pequenas ainda mantem igualdade, mas permite rolagem horizontal */
@media (max-width: 720px) {
  :root {
    --appverbo-admin-tab-width-v1: 90px;
    --appverbo-admin-action-min-width-v1: 120px;
  }

  #menu-tabs-card #submenu-items,
  #submenu-items {
    overflow-x: auto !important;
    flex-wrap: nowrap !important;
  }
}
/* APPVERBO_STANDARD_ADMIN_SUBPROCESS_BUTTONS_V1_END */

/* APPVERBO_ADMIN_SUBPROCESS_RENDER_FIX_V1_START */
/*
  Corrige estado em que a aba do subprocesso fica marcada,
  mas os cards abaixo continuam escondidos.
*/
body.appverbo-admin-subprocess-context #menu-tabs-card,
body.appverbo-admin-tab-entidade #menu-tabs-card,
body.appverbo-admin-tab-utilizador #menu-tabs-card,
body.appverbo-admin-tab-sessoes #menu-tabs-card,
body.appverbo-admin-tab-menu #menu-tabs-card,
body.appverbo-admin-tab-contas #menu-tabs-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body.appverbo-admin-tab-sessoes .admin-subprocess-card-v1[data-admin-subprocess="sessoes"],
body.appverbo-admin-tab-sessoes [data-admin-subprocess="sessoes"] {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body.appverbo-admin-tab-sessoes #home-summary-card {
  display: none !important;
}

body.appverbo-admin-tab-entidade #create-entity-card,
body.appverbo-admin-tab-entidade #edit-entity-card,
body.appverbo-admin-tab-entidade #recent-entities-card,
body.appverbo-admin-tab-entidade #inactive-entities-card,
body.appverbo-admin-tab-utilizador #create-user-card,
body.appverbo-admin-tab-sessoes #admin-sidebar-sections-card-create,
body.appverbo-admin-tab-sessoes #admin-sidebar-sections-card,
body.appverbo-admin-tab-sessoes #admin-sidebar-sections-card-inactive,
body.appverbo-admin-tab-menu #admin-menu-card-create,
body.appverbo-admin-tab-menu #admin-menu-card,
body.appverbo-admin-tab-menu #admin-menu-card-inactive,
body.appverbo-admin-tab-menu #settings-menu-edit-card,
body.appverbo-admin-tab-contas #admin-account-status-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}
/* APPVERBO_ADMIN_SUBPROCESS_RENDER_FIX_V1_END */

/* APPVERBO_SUBPROCESS_ACTIVE_GUARD_V1_START */
/*
  Garante que somente o subprocesso realmente selecionado fica azul.
  Evita o bug em que "Sessoes" continua marcado quando o conteudo e de Entidade,
  Utilizador ou Menu.
*/
#submenu-items [data-appverbo-force-inactive="true"] {
  background: #f9fbff !important;
  background-color: #f9fbff !important;
  border-color: #dce3f2 !important;
  color: #2f3850 !important;
  box-shadow: none !important;
  outline: none !important;
}

#submenu-items [data-appverbo-force-active="true"] {
  background: #1557b7 !important;
  background-color: #1557b7 !important;
  border-color: #1557b7 !important;
  color: #ffffff !important;
  box-shadow: none !important;
  outline: none !important;
}

#submenu-items [data-appverbo-force-active="true"] *,
#submenu-items [data-appverbo-force-active="true"] span {
  color: #ffffff !important;
}

#submenu-items [data-appverbo-force-inactive="true"] *,
#submenu-items [data-appverbo-force-inactive="true"] span {
  color: #2f3850 !important;
}
/* APPVERBO_SUBPROCESS_ACTIVE_GUARD_V1_END */

/* APPVERBO_SESSOES_RENDER_GUARD_V1_START */
/*
  Corrige o estado em que a aba Sessoes fica selecionada,
  mas os cards "Criar sessao", "Sessoes ativas" e "Sessoes inativas"
  continuam escondidos por classes de navegação anteriores.
*/
body.appverbo-sessoes-render-ok #menu-tabs-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body.appverbo-sessoes-render-ok [data-appverbo-sessoes-card="true"],
body.appverbo-sessoes-render-ok #admin-sidebar-sections-card-create,
body.appverbo-sessoes-render-ok #admin-sidebar-sections-card,
body.appverbo-sessoes-render-ok #admin-sidebar-sections-card-inactive,
body.appverbo-sessoes-render-ok [data-admin-subprocess="sessoes"] {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body.appverbo-sessoes-render-ok [data-appverbo-not-sessoes-card="true"],
body.appverbo-sessoes-render-ok #home-summary-card {
  display: none !important;
}

body.appverbo-sessoes-render-ok.appverbo-admin-process-only [data-appverbo-sessoes-card="true"],
body.appverbo-sessoes-render-ok.appverbo-admin-process-only #admin-sidebar-sections-card-create,
body.appverbo-sessoes-render-ok.appverbo-admin-process-only #admin-sidebar-sections-card,
body.appverbo-sessoes-render-ok.appverbo-admin-process-only #admin-sidebar-sections-card-inactive,
body.appverbo-sessoes-render-ok.appverbo-admin-process-only [data-admin-subprocess="sessoes"] {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}
/* APPVERBO_SESSOES_RENDER_GUARD_V1_END */

/* APPVERBO_ADMIN_MENU_NATIVE_V4_START */
/*
  Isolamento definitivo do subprocesso Administrativo > Menu.
  Quando Menu estiver ativo, somente os cards canónicos do subprocesso ficam visiveis.
*/
body.appverbo-menu-native-ok #menu-tabs-card,
body.appverbo-menu-native-ok #admin-menu-card,
body.appverbo-menu-native-ok #admin-menu-card-inactive,
body.appverbo-menu-native-ok #admin-menu-card-create,
body.appverbo-menu-native-ok #settings-menu-edit-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

body.appverbo-menu-native-ok .content .card:not(#menu-tabs-card):not(#admin-menu-card):not(#admin-menu-card-inactive):not(#admin-menu-card-create):not(#settings-menu-edit-card),
body.appverbo-menu-native-ok .content .admin-subprocess-card-v1:not(#menu-tabs-card):not(#admin-menu-card):not(#admin-menu-card-inactive):not(#admin-menu-card-create):not(#settings-menu-edit-card),
body.appverbo-menu-native-ok main .card:not(#menu-tabs-card):not(#admin-menu-card):not(#admin-menu-card-inactive):not(#admin-menu-card-create):not(#settings-menu-edit-card),
body.appverbo-menu-native-ok main .admin-subprocess-card-v1:not(#menu-tabs-card):not(#admin-menu-card):not(#admin-menu-card-inactive):not(#admin-menu-card-create):not(#settings-menu-edit-card) {
  display: none !important;
  visibility: hidden !important;
  opacity: 0 !important;
}

body.appverbo-menu-native-ok #home-summary-card,
body.appverbo-menu-native-ok #create-entity-card,
body.appverbo-menu-native-ok #create-user-card,
body.appverbo-menu-native-ok #admin-sidebar-sections-card,
body.appverbo-menu-native-ok #admin-account-status-card,
body.appverbo-menu-native-ok [data-admin-subprocess="entidade"],
body.appverbo-menu-native-ok [data-admin-subprocess="utilizador"],
body.appverbo-menu-native-ok [data-admin-subprocess="sessoes"],
body.appverbo-menu-native-ok [data-admin-subprocess="contas"] {
  display: none !important;
  visibility: hidden !important;
  opacity: 0 !important;
}

body.appverbo-menu-native-ok [data-admin-subprocess="menu"]#admin-menu-card,
body.appverbo-menu-native-ok [data-admin-subprocess="menu"]#admin-menu-card-inactive,
body.appverbo-menu-native-ok [data-admin-subprocess="menu"]#admin-menu-card-create,
body.appverbo-menu-native-ok [data-admin-subprocess="menu"]#settings-menu-edit-card {
  display: block !important;
  visibility: visible !important;
  opacity: 1 !important;
}

.appverbo-admin-menu-card-v3 .profile-card-header,
.appverbo-admin-menu-card-v4 .profile-card-header {
  align-items: flex-start;
}

.appverbo-admin-menu-subtitle-v3,
.appverbo-admin-menu-subtitle-v4 {
  margin: 4px 0 0;
  color: #667085;
  font-size: 13px;
}

.appverbo-admin-menu-list-v3,
.appverbo-admin-menu-list-v4 {
  margin-top: 14px;
}

.appverbo-admin-menu-table-v3 td,
.appverbo-admin-menu-table-v3 th,
.appverbo-admin-menu-table-v4 td,
.appverbo-admin-menu-table-v4 th {
  vertical-align: middle;
}

body.appverbo-menu-native-ok #submenu-items [data-appverbo-menu-active="true"] {
  background: #1557b7 !important;
  background-color: #1557b7 !important;
  border-color: #1557b7 !important;
  color: #ffffff !important;
}

body.appverbo-menu-native-ok #submenu-items [data-appverbo-menu-active="true"] * {
  color: #ffffff !important;
}

body.appverbo-menu-native-ok #submenu-items [data-appverbo-menu-inactive="true"] {
  background: #f9fbff !important;
  background-color: #f9fbff !important;
  border-color: #dce3f2 !important;
  color: #2f3850 !important;
  box-shadow: none !important;
}
/* APPVERBO_ADMIN_MENU_NATIVE_V4_END */


/* APPVERBO_SIDEBAR_OWNER_ENTITY_LABEL_V4_START */
.appverbo-sidebar-owner-card {
    margin: auto 14px 14px;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--sidebar-line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.62);
}

.appverbo-sidebar-owner-logo-wrap {
    width: 36px;
    height: 36px;
    flex: 0 0 36px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.appverbo-sidebar-owner-logo {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    object-fit: cover;
    display: block;
    border: 1px solid var(--sidebar-line);
    background: #fff;
}

.appverbo-sidebar-owner-logo-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 14px;
    color: #334155;
}

.appverbo-sidebar-owner-text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.appverbo-sidebar-owner-label {
    font-size: 10px;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
    font-weight: 700;
}

.appverbo-sidebar-owner-name {
    font-size: 13px;
    line-height: 1.2;
    color: #0f172a;
    font-weight: 800;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
/* APPVERBO_SIDEBAR_OWNER_ENTITY_LABEL_V4_END */

