:root {
  --bg: #eceef2;
  --topbar: #2f86d7;
  --sidebar-bg: #f3f3f4;
  --sidebar-line: #d7d9de;
  --sidebar-active: #e4e6ea;
  --panel-bg: #ffffff;
  --line: #d8dce4;
  --text: #2f3540;
  --muted: #6b7483;
  --primary: #3f51b5;
  --primary-hover: #35449d;
  --ok: #1f7a49;
  --ok-bg: #e9f8ef;
  --error: #a02a2a;
  --error-bg: #fdeeee;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  font-family: "Segoe UI", Tahoma, Arial, sans-serif;
  color: var(--text);
  background: var(--bg);
}

   .topbar {
  height: 62px;
  background: var(--topbar);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

   .topbar-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

   .brand {
  display: flex;
  align-items: center;
  gap: 8px;
  line-height: 1;
  font-weight: 700;
}

   .brand-mark {
  width: 32px;
  height: 32px;
  border-radius: 6px;
  background: rgba(255, 255, 255, 0.15);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 19px;
  overflow: hidden;
  flex: 0 0 32px;
}

   .brand-mark img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

   .brand-name {
  font-size: 22px;
  font-weight: 600;
  letter-spacing: 0.01em;
}

   .topbar-action {
  background: transparent;
  border: 0;
  color: #fff;
  font-size: 22px;
  cursor: pointer;
  padding: 0;
  margin-top: 0;
  line-height: 1;
}

   .topbar-right {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 13px;
  font-weight: 600;
}

   .topbar-meta {
  opacity: 0.95;
}

   .user-menu {
  position: relative;
}

   .user-menu-trigger {
  border: 1px solid rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.08);
  color: #fff;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  padding: 5px 8px;
  margin-top: 0;
  border-radius: 999px;
  min-height: 38px;
}

   .user-menu-trigger:hover {
  background: rgba(255, 255, 255, 0.18);
}

   .user-name {
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 14px;
  font-weight: 600;
}

   .avatar-img {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  border: 2px solid rgba(255, 255, 255, 0.75);
  background: #dbeafe;
  object-fit: cover;
  flex: 0 0 auto;
}

   .user-caret {
  font-size: 11px;
  opacity: 0.9;
}

   .user-dropdown {
  position: absolute;
  top: calc(100% + 12px);
  right: 0;
  width: min(430px, calc(100vw - 24px));
  background: #fff;
  border: 1px solid #bfc7d4;
  border-radius: 12px;
  box-shadow: 0 18px 40px rgba(16, 24, 40, 0.2);
  z-index: 40;
  padding: 18px 18px 14px;
}

   .user-dropdown::before {
  content: "";
  position: absolute;
  top: -8px;
  right: 30px;
  width: 14px;
  height: 14px;
  background: #fff;
  border-top: 1px solid #bfc7d4;
  border-left: 1px solid #bfc7d4;
  transform: rotate(45deg);
}

   .user-dropdown-header {
  padding: 0 0 14px;
  text-align: center;
  border-bottom: 1px solid #e1e6ef;
}

   .dropdown-avatar {
  width: 64px;
  height: 64px;
  border: 0;
  margin: 0 auto 12px;
  display: block;
  background: #cbe6ff;
}

   .dropdown-name {
  margin: 0;
  color: #0f2647;
  font-size: clamp(24px, 2vw, 32px);
  font-weight: 700;
  line-height: 1.1;
  word-break: break-word;
}

   .dropdown-meta {
  margin: 6px 0 0;
  color: #5d6981;
  font-size: 14px;
  font-weight: 600;
}

   .dropdown-email {
  margin: 6px 0 0;
  color: #1f2f4a;
  font-size: 15px;
  word-break: break-word;
}

   .dropdown-entity {
  margin: 4px 0 0;
  color: #1f2f4a;
  font-size: 14px;
  word-break: break-word;
}

   .user-dropdown-actions {
  padding: 12px 0 8px;
  display: grid;
  gap: 0;
}

   .dropdown-link {
  text-decoration: none;
  color: #102746;
  font-size: 16px;
  font-weight: 500;
  padding: 10px 2px;
  display: block;
  border-bottom: 1px solid #e8ecf3;
}

   .dropdown-link:hover {
  color: #0e5abc;
}

   .dropdown-logout-form {
  padding: 10px 0 0;
  margin: 0;
}

   .dropdown-logout-btn {
  width: 100%;
  margin: 0;
  background: transparent;
  color: #102746;
  border: 0;
  padding: 8px 2px;
  text-align: left;
  font-size: 16px;
  font-weight: 500;
  cursor: pointer;
  border-radius: 8px;
  transition: background-color 0.16s ease, color 0.16s ease;
}

   .dropdown-logout-btn:hover,
   .dropdown-logout-btn:focus-visible {
  background: #5f79cf;
  color: #ffffff;
  outline: none;
}

   .dropdown-logout-btn:active {
  background: #4f68b8;
  color: #ffffff;
}

   .layout {
  min-height: calc(100vh - 62px);
  display: grid;
  grid-template-columns: 234px minmax(0, 1fr);
}

   .sidebar {
  background: var(--sidebar-bg);
  border-right: 1px solid var(--sidebar-line);
  padding: 14px 0;
}

   .menu-section {
  margin: 10px 0 4px;
  padding: 0 18px;
  font-size: 13px;
  color: #808792;
  text-transform: uppercase;
}

   .menu-list {
  display: grid;
  gap: 1px;
  margin: 6px 0 14px;
}

   .menu-item {
  border: 0;
  background: transparent;
  width: 100%;
  text-align: left;
  padding: 11px 18px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #5c6572;
  font-size: 14px;
  cursor: pointer;
}

   .menu-item:hover {
  background: #eaecf0;
}

   .menu-item.active {
  background: var(--sidebar-active);
  color: #2f333a;
  font-weight: 700;
}

   .menu-icon {
  width: 20px;
  text-align: center;
  color: #7b8089;
  font-size: 12px;
}

   .menu-arrow {
  margin-left: auto;
  color: #8a9099;
}

   .perfil-submenu {
  padding: 4px 12px 10px 42px;
  margin: -8px 0 10px;
}

   .sidebar-submenu {
  padding: 0 12px;
  margin: -4px 0 10px;
}

   .sidebar-address-card {
  margin: 0 12px 14px;
  border: 1px solid #dce3f2;
  border-radius: 8px;
  background: #f9fbff;
  padding: 10px;
  display: grid;
  gap: 6px;
}

   .sidebar-address-title {
  margin: 0 0 4px;
  font-size: 13px;
  font-weight: 700;
  color: #2f3850;
  text-transform: uppercase;
}

   .sidebar-address-row {
  font-size: 13px;
  color: #344055;
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

   .sidebar-address-label {
  color: #667388;
  font-weight: 600;
}

   .submenu-items {
  display: grid;
  gap: 8px;
}

   .submenu-item {
  display: block;
  text-decoration: none;
  color: #2f3850;
  background: #f9fbff;
  border: 1px solid #dce3f2;
  border-radius: 8px;
  padding: 10px 11px;
  font-size: 13px;
  font-weight: 600;
}

   .submenu-item:hover {
  background: #f2f6ff;
  border-color: #becdf0;
}

   .submenu-item.active {
  background: #edf3ff;
  border-color: #b5c7ee;
  color: #22304f;
}

   .menu-tabs-card {
  padding: 0;
  overflow: hidden;
}

   .menu-tabs {
  display: flex;
  align-items: center;
  gap: 2px;
  overflow-x: auto;
  border-bottom: 1px solid #dce3f2;
  padding: 0 10px;
}

   .menu-tabs .submenu-item {
  text-transform: none;
}

   .menu-tabs.submenu-item {
  background: transparent;
  border: 0;
  border-bottom: 3px solid transparent;
  border-radius: 0;
  padding: 13px 10px 11px;
  white-space: nowrap;
  color: #33425c;
  font-weight: 700;
  font-size: 14px;
}

   .menu-tabs.submenu-item:hover {
  background: #f4f7fd;
  border-color: transparent;
}

   .menu-tabs.submenu-item.active {
  background: transparent;
  border-color: #1c67c9;
  color: #0e5abc;
}

   .content {
  padding: 24px;
  min-width: 0;
}

   .container {
  width: 100%;
  max-width: 100%;
}

   .card {
  background: var(--panel-bg);
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 18px;
  margin-bottom: 14px;
}

   .entity-create-collapse {
  border: 0;
  text-align: left;
}

   .entity-create-toolbar {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  flex-wrap: wrap;
  border: 0;
  background: transparent;
  box-shadow: none;
  padding: 0;
  margin: 0;
}

   .entity-create-toolbar > * {
  margin: 0;
}

   .entity-create-toolbar .entity-create-collapse {
  margin: 0;
}

   .entity-create-toolbar .entity-create-collapse[open] {
  flex: 1 1 100%;
}

   .entity-create-toolbar .entity-create-collapse[open] + .entity-create-link-shortcut {
  display: none;
}

   .entity-create-collapse summary {
  list-style: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--ui-control-height);
  min-height: var(--ui-control-height);
  font-size: var(--ui-button-font-size);
  font-weight: var(--ui-button-font-weight);
  line-height: var(--ui-button-line-height);
  color: #ffffff;
  margin-bottom: 0;
  width: auto;
  border-radius: var(--ui-button-border-radius);
  padding: 0 var(--ui-button-padding-x);
  background: #0e5abc;
  border: 1px solid #2458c3;
  transition: background 0.15s ease, border-color 0.15s ease;
  margin-top: 0;
}

   .entity-create-collapse summary:hover {
  background: #1c67c9;
  border-color: #1c67c9;
}

   .entity-create-collapse summary::-webkit-details-marker {
  display: none;
}

   .entity-create-collapse[open] > summary {
  display: none;
}

   .entity-create-link-shortcut {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--ui-control-height);
  margin-top: 0;
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-button-padding-x);
  border: 1px solid #72819d;
  white-space: nowrap;
}

   .entity-create-link-slot {
  flex: 1 1 420px;
  min-width: min(420px, 100%);
  min-height: var(--ui-control-height);
}

   .entity-create-link-output {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
}

   .entity-create-link-output input {
  min-width: 220px;
  flex: 1 1 auto;
  margin: 0;
}

   .entity-create-link-message {
  min-height: var(--ui-control-height);
  display: flex;
  align-items: center;
  padding: 0 12px;
  border: 1px solid #d7ddea;
  background: #f8fafc;
  color: #546174;
  font-size: 13px;
  font-weight: 600;
}

   .entity-create-link-copy-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--ui-control-height);
  margin-top: 0;
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-button-padding-x);
  border: 1px solid #72819d;
  white-space: nowrap;
}

   .entity-create-body {
  margin-top: 10px;
  text-align: left;
}

   .entity-first-row {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-first-row.field {
  min-width: 0;
}

   .entity-first-row.field label {
  white-space: nowrap;
  line-height: 1.2;
}

   .entity-first-row.entity-first-row-client,
   .entity-first-row.entity-first-row-acronym {
  width: max-content;
}

   .entity-first-row.entity-first-row-client input {
  width: 100%;
  min-width: 10ch;
}

   .entity-first-row.entity-first-row-acronym input {
  width: 100%;
  min-width: 5ch;
}

   .entity-second-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-second-row.field {
  min-width: 0;
}

   .entity-second-row.field label {
  white-space: nowrap;
  line-height: 1.2;
}

   .entity-second-row.entity-second-row-tax,
   .entity-second-row.entity-second-row-phone {
  width: max-content;
}

   .entity-second-row.entity-second-row-tax input {
  width: 100%;
  min-width: 30ch;
  max-width: 30ch;
}

   .entity-second-row.entity-second-row-phone input {
  width: 100%;
  min-width: 30ch;
  max-width: 30ch;
}

   .entity-third-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-third-row.field {
  min-width: 0;
}

   .entity-third-row.field label {
  white-space: nowrap;
  line-height: 1.2;
}

   .entity-third-row.entity-third-row-door {
  width: max-content;
}

   .entity-third-row.entity-third-row-door input {
  width: 100%;
  min-width: 15ch;
  max-width: 15ch;
}

   .entity-fourth-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-fourth-row.field {
  min-width: 0;
}

   .entity-fourth-row.field label {
  white-space: nowrap;
  line-height: 1.2;
}

   .entity-fourth-row.entity-fourth-row-postal,
   .entity-fourth-row.entity-fourth-row-country {
  width: max-content;
}

   .entity-fourth-row.entity-fourth-row-postal input {
  width: 100%;
  min-width: 30ch;
  max-width: 30ch;
}

   .entity-fourth-row.entity-fourth-row-country input {
  width: 100%;
  min-width: 50ch;
  max-width: 50ch;
}

   .entity-fifth-row-created-at {
  width: max-content;
}

   .entity-fifth-row-created-at input {
  width: 100%;
  min-width: 30ch;
  max-width: 30ch;
}

   .entity-fifth-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-scope-row {
  display: grid;
  grid-template-columns: minmax(260px, 320px);
  gap: 12px;
  margin-bottom: 12px;
}

   .entity-fifth-row-edit {
  grid-template-columns: minmax(0, 1fr) auto auto;
}

   .entity-fifth-row.field {
  min-width: 0;
}

   .entity-edit-logo-row {
  margin-bottom: 12px;
}

   .entity-edit-status-row {
  max-width: 240px;
  min-width: 220px;
}

   .entity-edit-current-logo {
  min-width: 0;
}

   .entity-edit-current-logo-preview {
  position: relative;
  width: 100%;
  max-width: 360px;
}

   .entity-edit-current-logo-image {
  display: block;
  width: 100%;
  height: 120px;
  object-fit: contain;
  object-position: center;
  border: 1px solid #d8deea;
  border-radius: 10px;
  background: #ffffff;
  padding: 8px;
}

   .entity-edit-remove-logo-placeholder {
  display: none;
  width: 100%;
  height: 120px;
  border: 1px dashed #d9a8a8;
  border-radius: 10px;
  background: #fff7f7;
  color: #8f2f2f;
  font-size: 13px;
  font-weight: 600;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 8px 12px;
}

   .entity-edit-remove-logo-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

   .entity-edit-remove-logo-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  width: 26px;
  height: 26px;
  border-radius: 999px;
  border: 1px solid #e4a8a8;
  background: #ffffff;
  color: #8f2f2f;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  line-height: 1;
  cursor: pointer;
  box-shadow: 0 2px 6px rgba(36, 49, 74, 0.15);
  user-select: none;
}

   .entity-edit-remove-logo-btn:hover {
  background: #fdeeee;
  border-color: #d57a7a;
  color: #7d2525;
}

   .entity-edit-remove-logo-input:checked +.entity-edit-remove-logo-btn {
  background: #fdeeee;
  border-color: #d57a7a;
  color: #7d2525;
}

   .entity-edit-remove-logo-input:checked ~ .entity-edit-current-logo-image {
  display: none;
}

   .entity-edit-remove-logo-input:checked ~ .entity-edit-remove-logo-placeholder {
  display: flex;
}

   .entity-panel-card {
  border-radius: 18px;
  border: 1px solid #d6dde9;
  background: #f5f7fb;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

   .entity-panel-card h2 {
  color: #0f2647;
}

   .home-summary-head {
  display: grid;
  gap: 6px;
  margin-bottom: 12px;
}

   .home-summary-head h2 {
  margin: 0;
}

   .home-summary-head p {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
}

   .home-kpis {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
  margin-bottom: 14px;
}

   .home-kpi {
  border: 1px solid #d6dce8;
  background: #fafcff;
  border-radius: 8px;
  padding: 10px;
}

   .home-kpi-label {
  margin: 0;
  color: #64728a;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
}

   .home-kpi-value {
  margin: 8px 0 0;
  font-size: 26px;
  font-weight: 700;
  line-height: 1;
  color: #2f3850;
}

   .home-chart-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

   .home-chart-box {
  border: 1px solid #d6dce8;
  background: #fcfdff;
  border-radius: 8px;
  padding: 12px;
  min-height: 300px;
  display: grid;
  gap: 8px;
  align-content: start;
}

   .home-chart-box h3 {
  margin: 0;
  font-size: 16px;
  color: #2f3850;
}

   .home-chart-wrap {
  position: relative;
  height: 230px;
}

   .personal-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px 16px;
}

   .profile-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-bottom: 12px;
}

   .profile-card-header h2 {
  margin: 0;
}

   .profile-edit-toggle {
  margin: 0;
  padding: 8px 12px;
  font-size: 13px;
}

   .profile-edit-form {
  display: none;
}

   .card.editing .profile-readonly {
  display: none;
}

   .card.editing .profile-edit-form {
  display: block;
}

   .card.editing .profile-edit-toggle {
  display: none;
}

   #dynamic-process-card.dynamic-process-open .profile-readonly {
  display: none;
}

   #dynamic-process-card.dynamic-process-open .profile-edit-form {
  display: block;
}

   #dynamic-process-card.dynamic-process-open .profile-edit-toggle {
  display: none;
}

   .profile-edit-actions {
  margin-top: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

   .profile-edit-actions button {
  margin-top: 0;
  min-width: 132px;
  min-height: var(--ui-control-height);
}

   .profile-process-tabs {
  margin: 0 0 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  border-bottom: 1px solid #d5deee;
  padding-bottom: 8px;
}

   .profile-process-tab-btn {
  border: 1px solid #c4d1ec;
  background: #eef3ff;
  color: #233b66;
  border-radius: 6px;
  padding: 6px 12px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
}

   .profile-process-tab-btn:hover {
  background: #e3ecff;
  border-color: #b4c6eb;
}

   .profile-process-tab-btn.active {
  background: #3f51b5;
  border-color: #3f51b5;
  color: #ffffff;
}

   .profile-cancel-btn {
  background: #8b95a7;
}

   .profile-cancel-btn:hover {
  background: #727d91;
}

   .training-options-grid {
  display: grid;
  gap: 10px;
}

   .training-option-row {
  border: 1px solid #d6dce8;
  background: #fafcff;
  border-radius: 6px;
  padding: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

   .training-option-row input[type="checkbox"] {
  width: auto;
  margin: 0;
}

   .training-option-row span {
  font-weight: 600;
  color: #2c3649;
}

   .training-option-outros {
  justify-content: space-between;
  flex-wrap: wrap;
}

   .training-outros-label {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 0;
  color: #2c3649;
  font-weight: 600;
}

   .training-outros-input {
  flex: 1 1 auto;
  min-width: 220px;
  min-height: var(--ui-control-height);
  margin: 0;
  padding: 0 var(--ui-control-padding-x);
  border: 1px solid var(--ui-control-border-color);
  border-radius: var(--ui-control-border-radius);
  font-size: var(--ui-control-font-size);
  color: #313845;
  background: #fff;
}

   .training-outros-input:disabled {
  background: #eef1f6;
  color: #7b869a;
}

   .training-selected-list {
  margin: 8px 0 14px;
  padding-left: 18px;
  color: #2c3649;
}

   .training-selected-list li {
  margin-bottom: 4px;
}

   .personal-item {
  border: 1px solid #d6dce8;
  background: #fafcff;
  border-radius: 6px;
  padding: 10px;
}

   .personal-label {
  display: block;
  font-size: 12px;
  text-transform: none;
  color: #68748a;
  margin-bottom: 4px;
  font-weight: 600;
}

   .personal-value {
  display: block;
  font-size: 15px;
  color: #2c3649;
  word-break: break-word;
}

h1,
h2 {
  margin: 0 0 12px;
  font-weight: 700;
  color: #2f3a4a;
}

p {
  margin: 0 0 12px;
  color: var(--muted);
}

   .grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

   .settings-general-grid {
  grid-template-columns: minmax(280px, 2fr) minmax(220px, 1fr) minmax(220px, 1fr);
}

   .settings-general-grid-menu-geral {
  grid-template-columns: minmax(260px, 1.6fr) minmax(180px, 0.8fr) minmax(180px, 0.8fr) minmax(180px, 0.8fr);
}

   .field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

   .field.full {
  grid-column: 1 / -1;
}

label {
  font-size: 13px;
  color: #586273;
  text-transform: uppercase;
}

   .profile-edit-form label {
  text-transform: none;
}

   .profile-edit-form input[type="checkbox"] {
  width: auto;
  margin-right: 8px;
  vertical-align: middle;
}

   .profile-custom-flag-control {
  width: 100%;
  min-height: var(--ui-control-height);
  border: 1px solid var(--ui-control-border-color);
  border-radius: var(--ui-control-border-radius);
  background: #fff;
  padding: 0 var(--ui-control-padding-x);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #313845;
  font-size: var(--ui-control-font-size);
  font-weight: 500;
}

   .profile-multi-value-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

   .profile-multi-value-list {
  display: grid;
  gap: 6px;
}

   .profile-multi-value-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

   .profile-multi-value-row input,
   .profile-multi-value-row select,
   .profile-multi-value-row textarea {
  flex: 1 1 auto;
  min-width: 0;
}

   .profile-multi-value-add-btn,
   .profile-multi-value-remove-btn {
  width: 30px;
  min-width: 30px;
  height: 30px;
  min-height: 30px;
  padding: 0;
  margin: 0;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

input,
select,
textarea {
  width: 100%;
  border: 1px solid var(--ui-control-border-color);
  border-radius: var(--ui-control-border-radius);
  background: #fff;
  color: #313845;
  font-size: var(--ui-control-font-size);
}

input,
select {
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-control-padding-x);
}

textarea {
  padding: 10px var(--ui-control-padding-x);
  min-height: 92px;
  resize: vertical;
}

button {
  margin-top: 0;
  border: 0;
  border-radius: var(--ui-button-border-radius);
  background: var(--primary);
  color: #fff;
  padding: 0 var(--ui-button-padding-x);
  font-size: var(--ui-button-font-size);
  font-weight: var(--ui-button-font-weight);
  line-height: var(--ui-button-line-height);
  cursor: pointer;
}

button:hover {
  background: var(--primary-hover);
}

   .alert {
  border-radius: 6px;
  padding: 10px 12px;
  margin-bottom: 12px;
  border: 1px solid;
  font-size: 14px;
}

   .alert.ok {
  color: var(--ok);
  background: var(--ok-bg);
  border-color: #b8e7c9;
}

   .alert.error {
  color: var(--error);
  background: var(--error-bg);
  border-color: #f5c7c7;
}

   .alert ul {
  margin: 0;
  padding-left: 18px;
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
  background: #fff;
}

th,
td {
  border-bottom: 1px solid #d9dee8;
  text-align: left;
  padding: 10px 8px;
}

th {
  color: #5f6877;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 12px;
}

   .empty {
  color: var(--muted);
}

   .table-limiter {
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}

   .table-limiter-left {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: #5f6877;
  font-size: 14px;
}

   .readonly-field {
  background: #eef1f6 !important;
  border-color: #d6dce8 !important;
  color: #5f6877 !important;
  cursor: not-allowed;
}

   .entity-panel-card[data-readonly-mode="1"] input:disabled,
   .entity-panel-card[data-readonly-mode="1"] select:disabled,
   .entity-panel-card[data-readonly-mode="1"] textarea:disabled {
  background: #eef1f6 !important;
  border-color: #d6dce8 !important;
  color: #5f6877 !important;
  cursor: not-allowed;
}

   .table-limiter-select {
  width: auto;
  min-width: 84px;
  min-height: 34px;
  padding: 6px 10px;
  border-radius: 8px;
  font-size: 14px;
  color: #253046;
}

   .table-limiter-right {
  display: inline-flex;
  align-items: center;
  gap: 10px;
}

   .table-limiter-nav-btn {
  margin-top: 0;
  width: 30px;
  height: 30px;
  padding: 0;
  border-radius: 999px;
  background: transparent;
  color: #2f6db4;
  border: 1px solid #d3dced;
  font-size: 18px;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

   .table-limiter-nav-btn:hover {
  background: #eef3ff;
  color: #1f4eb7;
  border-color: #becdf0;
}

   .table-limiter-nav-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  background: transparent;
  color: #7a879d;
  border-color: #d9dee8;
}

   .table-limiter-page {
  min-width: 30px;
  height: 30px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #2f6db4;
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  line-height: 1;
}

   .entity-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 3px 8px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 700;
  border: 1px solid transparent;
  white-space: nowrap;
}

   .entity-status-active {
  color: #17663f;
  background: #e9f8ef;
  border-color: #b7e3c7;
}

   .entity-status-inactive {
  color: #7a2f2f;
  background: #fdeeee;
  border-color: #f2c2c2;
}

   .table-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

   .table-actions form {
  margin: 0;
  display: inline-flex;
  align-items: center;
}

   .table-link-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  border: 1px solid #c5d2ed;
  background: #eef3ff;
  color: #25385e;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 700;
  padding: 6px 10px;
  cursor: pointer;
}

   .table-link-btn:hover {
  background: #e2eaff;
  border-color: #afc0e7;
}

   .table-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  margin-top: 0;
  padding: 0;
  text-decoration: none;
  border: 1px solid #c5d2ed;
  background: #eef3ff;
  color: #25385e;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  line-height: 1;
}

   .table-icon-btn:hover {
  background: #e2eaff;
  border-color: #afc0e7;
}

   .table-icon-btn-disabled {
  opacity: 0.45;
  cursor: not-allowed;
  pointer-events: none;
}

   .table-icon-btn-danger {
  border-color: #f0c0c0;
  background: #fdeeee;
  color: #8f2f2f;
}

   .table-icon-btn-danger:hover {
  border-color: #e4a8a8;
  background: #fbdede;
  color: #7d2525;
}

   .entity-logo-preview {
  margin-top: 6px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #5f6877;
  font-size: 13px;
}

   .entity-logo-preview img {
  width: 58px;
  height: 58px;
  border-radius: 8px;
  border: 1px solid #d8deea;
  object-fit: cover;
  background: #fff;
}

   .form-action-row {
  margin-top: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

   .action-btn {
  margin-top: 0;
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-button-padding-x);
}

   .action-btn-cancel {
  margin-top: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  border: 1px solid #c5d2ed;
  background: #eef3ff;
  color: #25385e;
  border-radius: var(--ui-button-border-radius);
  padding: 0 var(--ui-button-padding-x);
  min-height: var(--ui-control-height);
  font-size: var(--ui-button-font-size);
  font-weight: var(--ui-button-font-weight);
  line-height: var(--ui-button-line-height);
  cursor: pointer;
}

   .action-btn-cancel:hover {
  background: #e2eaff;
  border-color: #afc0e7;
}

   .form-action-row .action-btn,
   .form-action-row .action-btn-cancel,
   .form-action-row .action-btn-secondary,
   .form-action-row .action-btn-danger {
  min-width: 132px;
}

   .process-window-card {
  border: 1px solid #c7d4ef;
  box-shadow: 0 10px 28px rgba(28, 53, 99, 0.15);
}

   .process-edit-tabs {
  margin: 6px 0 12px;
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
  border-bottom: 1px solid #cdd8ee;
  padding-bottom: 0;
}

   .process-edit-tab-link {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  margin: 0;
  padding: 10px 14px;
  border: 1px solid transparent;
  border-bottom: 2px solid transparent;
  border-radius: 8px 8px 0 0;
  background: transparent;
  color: #39527f;
  font-size: 13px;
  font-weight: 700;
  line-height: 1.2;
  cursor: pointer;
  user-select: none;
}

   .process-edit-tab-link:hover {
  background: #eef3ff;
  color: #25385e;
}

   .process-edit-tab-link.active {
  background: #ffffff;
  color: #1f3660;
  border-color: #cdd8ee;
  border-bottom-color: #3f51b5;
}

   .process-edit-pane {
  display: none;
}

   .process-edit-pane.active {
  display: block;
}

   .process-fields-builder {
  display: grid;
  gap: 10px;
}

   .process-visible-fields {
  display: grid;
  gap: 8px;
}

   .process-field-row {
  display: grid;
  grid-template-columns: minmax(240px, 1fr) minmax(240px, 1fr) auto;
  gap: 8px;
  align-items: end;
}

   .process-additional-fields-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
}

.process-additional-field-row {
  display: grid;
  grid-template-columns:
    minmax(260px, 1.2fr)
    minmax(180px, 0.8fr)
    minmax(140px, 0.5fr)
    minmax(140px, 0.4fr)
    minmax(180px, 0.8fr)
    auto
    auto;
  gap: 8px;
  align-items: end;
}

.process-additional-field-row .field-move-buttons {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  align-self: end;
  min-width: 76px;
}

.process-additional-field-row .field-move-buttons-row {
  display: inline-flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 4px;
  align-items: center;
  justify-content: flex-start;
  white-space: nowrap;
}

.process-additional-field-row .field-move-buttons form {
  margin: 0;
  padding: 0;
  display: inline-flex;
  flex: 0 0 auto;
}

.process-additional-field-row .field-move-buttons .table-icon-btn {
  width: 34px;
  height: 34px;
  min-width: 34px;
  min-height: 34px;
  padding: 0;
  font-size: 14px;
}

.process-additional-field-row .field {
  min-width: 0;
  margin-bottom: 0;
}

.process-additional-field-row .additional-field-list-col-v5 {
  min-width: 0;
}

.process-additional-field-row .additional-field-list-col-v5 select {
  width: 100%;
}

.process-additional-field-row .additional-field-list-col-v5.is-disabled select {
  background: #eef2fb;
  color: #5a6580;
  cursor: not-allowed;
}

   .process-additional-field-row.process-additional-field-row-header,
   .process-additional-field-row.process-additional-field-row-header .field label,
   .process-additional-field-row.process-additional-field-row-header input,
   .process-additional-field-row.process-additional-field-row-header select,
   .process-additional-field-row.process-additional-field-row-header .table-icon-btn {
  font-weight: 700;
}

   .process-additional-size-readonly {
  background: #eef2fb;
  color: #5a6580;
}

   .process-field-row .field {
  margin-bottom: 0;
}

   .process-field-select {
  margin-top: 0;
}

   .process-field-add-btn {
  width: 34px;
}

   .action-btn-secondary {
  background: #7f8aa1;
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-button-padding-x);
}

   .action-btn-secondary:hover {
  background: #6a768f;
}

   .action-btn-danger {
  background: #ad2d2d;
  min-height: var(--ui-control-height);
  padding: 0 var(--ui-button-padding-x);
}

   .action-btn-danger:hover {
  background: #912525;
}

   .action-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

   .admin-subsection {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid #d9dee8;
}

   .admin-subsection h3 {
  margin-top: 0;
}

   .sidebar-sections-subtitle {
  margin: 0 0 8px;
  font-size: 15px;
  color: #2f3a4a;
}

   .sidebar-sections-block {
  margin-top: 12px;
  padding: 12px;
  border: 1px solid #d9dee8;
  border-radius: 8px;
  background: #fafcff;
}

   .sidebar-sections-create-actions {
  margin-top: 0;
  margin-bottom: 10px;
}

   .sidebar-sections-created-table td:last-child,
   .sidebar-sections-created-table th:last-child {
  width: 132px;
}

   .sidebar-sections-actions {
  justify-content: flex-end;
}

   .superuser-list {
  margin: 0;
  padding-left: 18px;
  display: grid;
  gap: 8px;
  color: #2f3850;
  font-size: 14px;
}

@media (max-width: 1200px) {
 .layout {
    grid-template-columns: 210px minmax(0, 1fr);
  }

  .settings-general-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .settings-general-grid-menu-geral {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
 .layout {
    grid-template-columns: 190px minmax(0, 1fr);
  }
}

@media (max-width: 760px) {
 .layout {
    grid-template-columns: 1fr;
  }

 .sidebar {
    border-right: 0;
    border-bottom: 1px solid var(--line);
  }
}

@media (max-width: 760px) {
 .topbar-right {
    gap: 8px;
  }

 .user-name {
    display: none;
  }

 .user-dropdown {
    right: 0;
    width: min(430px, calc(100vw - 16px));
  }

 .content {
    padding: 14px;
  }

 .grid {
    grid-template-columns: 1fr;
  }

  .process-field-row {
    grid-template-columns: 1fr;
  }

  .process-additional-fields-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  .process-additional-field-row {
    grid-template-columns: 1fr;
  }

  .entity-first-row {
    grid-template-columns: 1fr;
  }

 .entity-second-row {
    grid-template-columns: 1fr;
  }

 .entity-third-row {
    grid-template-columns: 1fr;
  }

 .entity-fourth-row {
    grid-template-columns: 1fr;
  }

 .entity-fifth-row {
    grid-template-columns: 1fr;
  }

 .entity-scope-row {
    grid-template-columns: 1fr;
  }

 .personal-grid {
    grid-template-columns: 1fr;
  }

 .home-kpis {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

 .home-chart-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 540px) {
 .home-kpis {
    grid-template-columns: 1fr;
  }
}

/* ###################################################################################
   (PERFIL) Dados pessoais: Nome, Telefone e Email na primeira linha
################################################################################### */

#perfil-pessoal-card .profile-edit-form .personal-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

#perfil-pessoal-card .profile-edit-form .field.full {
  grid-column: 1 / -1;
}

#perfil-pessoal-card .profile-edit-form #edit_login_email {
  background: #ffffff;
}

@media (max-width: 1100px) {
  #perfil-pessoal-card .profile-edit-form .personal-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  #perfil-pessoal-card .profile-edit-form .personal-grid {
    grid-template-columns: 1fr;
  }
}

/* ###################################################################################
   (PERFIL) Ordem dos campos: Nome | Telefone | Email
################################################################################### */

#perfil-pessoal-card .profile-edit-form .personal-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

#perfil-pessoal-card .profile-edit-form .profile-field-name {
  order: 1;
}

#perfil-pessoal-card .profile-edit-form .profile-field-phone {
  order: 2;
}

#perfil-pessoal-card .profile-edit-form .profile-field-email {
  order: 3;
}

#perfil-pessoal-card .profile-edit-form .profile-field-country {
  order: 4;
}

#perfil-pessoal-card .profile-edit-form .field:has(#edit_full_name) {
  order: 1;
}

#perfil-pessoal-card .profile-edit-form .field:has(#edit_primary_phone) {
  order: 2;
}

#perfil-pessoal-card .profile-edit-form .field:has(#edit_login_email) {
  order: 3;
}

#perfil-pessoal-card .profile-edit-form .field:has(#edit_country) {
  order: 4;
}

#perfil-pessoal-card .profile-edit-form .field.full:has(#edit_login_email) {
  grid-column: auto;
}

@media (max-width: 1100px) {
  #perfil-pessoal-card .profile-edit-form .personal-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  #perfil-pessoal-card .profile-edit-form .personal-grid {
    grid-template-columns: 1fr;
  }
}

/* ###################################################################################
   (CONFIG) Campos adicionais com Hierarquia visível ao lado do Tamanho
################################################################################### */

.additional-field-row-equalized {
  display: grid;
  grid-template-columns:
    minmax(260px, 2.05fr)
    minmax(220px, 1.35fr)
    minmax(145px, 0.75fr)
    minmax(120px, 0.6fr)
    minmax(135px, 0.65fr)
    42px;
  gap: 12px;
  align-items: end;
  width: 100%;
  margin-bottom: 12px;
}

.additional-field-row-equalized > .field,
.additional-field-row-equalized > div {
  min-width: 0;
}

.additional-field-name-col {
  grid-column: 1;
}

.additional-field-type-col {
  grid-column: 2;
}

.additional-field-required-col {
  grid-column: 3;
}

.additional-field-size-col {
  grid-column: 4;
}

.additional-field-hierarchy-col {
  grid-column: 5;
  min-height: 38px;
  display: flex;
  align-items: flex-end;
}

.additional-field-hierarchy-col.is-empty {
  visibility: hidden;
}

.additional-field-action-col {
  grid-column: 6;
  align-self: end;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
}

.additional-field-row-equalized label {
  min-height: 16px;
}

.additional-field-row-equalized input,
.additional-field-row-equalized select {
  width: 100%;
}

.header-hierarchy-controls {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.header-hierarchy-label {
  font-size: 10px;
  font-weight: 700;
  color: #4b5b7a;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1;
}

.header-hierarchy-buttons {
  display: flex;
  gap: 6px;
}

.header-hierarchy-btn {
  width: 30px;
  height: 28px;
  border: 1px solid #b8cdf8;
  border-radius: 7px;
  background: #eff5ff;
  color: #1f4fa3;
  font-weight: 800;
  line-height: 1;
  cursor: pointer;
}

.header-hierarchy-btn:hover {
  background: #dfeaff;
  border-color: #8fb0f2;
}

.header-hierarchy-btn:active {
  transform: translateY(1px);
}

@media (max-width: 1300px) {
  .additional-field-row-equalized {
    grid-template-columns: repeat(2, minmax(0, 1fr)) minmax(135px, 0.75fr) 42px;
  }

  .additional-field-name-col {
    grid-column: 1;
  }

  .additional-field-type-col {
    grid-column: 2;
  }

  .additional-field-required-col {
    grid-column: 1;
  }

  .additional-field-size-col {
    grid-column: 2;
  }

  .additional-field-hierarchy-col {
    grid-column: 3;
  }

  .additional-field-action-col {
    grid-column: 4;
    grid-row: 1 / span 2;
  }
}

@media (max-width: 760px) {
  .additional-field-row-equalized {
    grid-template-columns: 1fr;
  }

  .additional-field-name-col,
  .additional-field-type-col,
  .additional-field-required-col,
  .additional-field-size-col,
  .additional-field-hierarchy-col,
  .additional-field-action-col {
    grid-column: 1;
    grid-row: auto;
  }

  .additional-field-action-col {
    justify-content: flex-start;
  }
}

/* ###################################################################################
   Processo Lista V3
################################################################################### */

.process-lists-panel-v3 {
  margin-top: 16px;
}

.process-lists-rows-v3 {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.process-list-row-v3 {
  display: grid;
  grid-template-columns: minmax(220px, 1fr) minmax(320px, 2fr) auto;
  gap: 12px;
  align-items: end;
  width: 100%;
}

.process-list-actions-v3 {
  display: flex;
  align-items: end;
  justify-content: flex-start;
}

.additional-field-list-col-v3 {
  min-width: 180px;
}

@media (max-width: 900px) {
  .process-list-row-v3 {
    grid-template-columns: 1fr;
  }
}


/* ###################################################################################
   Processo Listas V5
################################################################################### */

.process-lists-panel-v5 {
  margin-top: 16px;
}

.process-lists-rows-v5 {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.process-list-row-v5 {
  display: grid;
  grid-template-columns: minmax(220px, 1fr) minmax(320px, 2fr) auto;
  gap: 12px;
  align-items: end;
  width: 100%;
}

.process-list-actions-v5 {
  display: flex;
  align-items: end;
  justify-content: flex-start;
}

.additional-field-list-col-v5 {
  min-width: 180px;
}

@media (max-width: 900px) {
  .process-list-row-v5 {
    grid-template-columns: 1fr;
  }
}


/* ###################################################################################
   Processo Listas Layout V1
################################################################################### */

.process-lists-panel-v6 {
  margin-top: 16px;
}

.process-lists-panel-v6 .muted {
  margin-bottom: 14px;
}

.process-lists-rows-v6 {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.process-list-row-v6 {
  display: grid;
  grid-template-columns: minmax(220px, 0.75fr) minmax(420px, 1.75fr);
  gap: 14px;
  align-items: end;
  width: 100%;
}

.process-list-row-v6 .field {
  min-width: 0;
}

.process-list-row-v6 input {
  width: 100%;
}

.process-lists-actions-v6 {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-top: 14px;
}

@media (max-width: 900px) {
  .process-list-row-v6 {
    grid-template-columns: 1fr;
  }
}


/* ###################################################################################
   Processo Listas Layout V2
################################################################################### */

.process-lists-panel-v7 {
  margin-top: 16px;
}

.process-lists-panel-v7 .muted {
  margin-bottom: 14px;
}

.process-lists-block-v7 {
  margin-top: 18px;
  padding-top: 14px;
  border-top: 1px solid #d9e3f8;
}

.process-lists-block-v7:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: 0;
}

.process-lists-block-v7 h4 {
  margin: 0 0 12px;
  color: #1f2f4d;
  font-size: 14px;
  font-weight: 700;
}

.process-lists-rows-v7 {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.process-list-row-v7 {
  display: grid;
  grid-template-columns: minmax(220px, 0.75fr) minmax(420px, 1.75fr) auto;
  gap: 14px;
  align-items: end;
  width: 100%;
}

.process-list-row-create-v7 {
  grid-template-columns: minmax(220px, 0.75fr) minmax(420px, 1.75fr);
}

.process-list-row-v7 .field {
  min-width: 0;
}

.process-list-row-v7 input {
  width: 100%;
}

.process-list-actions-col-v7 {
  display: inline-flex;
  align-items: end;
  justify-content: flex-start;
}

.process-lists-empty-v7 {
  margin: 0;
}

.field-example-v7 {
  display: block;
  margin-top: 2px;
  margin-bottom: 6px;
  color: #6b7280;
  font-size: 11px;
  line-height: 1.2;
}

.process-lists-actions-v7 {
  display: flex;
  gap: 8px;
  align-items: center;
  margin-top: 14px;
}

.process-lists-cancel-v7 {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 104px;
  height: 38px;
  padding: 0 18px;
  border: 1px solid #b8cdf8;
  border-radius: 7px;
  background: #eef4ff;
  color: #1f4fa3;
  font-weight: 700;
  text-decoration: none;
  box-sizing: border-box;
}

.process-lists-cancel-v7:hover {
  background: #dfeaff;
  border-color: #8fb0f2;
  text-decoration: none;
}

.process-subsequent-block-v7 {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid #d8e0f1;
}

.process-subsequent-block-v7:first-of-type {
  margin-top: 0;
  padding-top: 0;
  border-top: 0;
}

.process-subsequent-block-v7 h4 {
  margin: 0 0 12px;
  color: #1f3660;
  font-size: 16px;
  font-weight: 700;
}

.process-subsequent-block-v7 .process-subsequent-fields-grid {
  display: grid;
  gap: 12px;
}

.process-subsequent-field-row {
  display: grid;
  grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) minmax(180px, 0.9fr) minmax(180px, 1fr) auto;
  gap: 10px;
  align-items: end;
}

.process-subsequent-field-row .field {
  min-width: 0;
  margin-bottom: 0;
}

.process-subsequent-field-row .field input,
.process-subsequent-field-row .field select {
  width: 100%;
}

.process-subsequent-field-row .field.is-disabled input {
  background: #eef2fb;
  color: #5a6580;
  cursor: not-allowed;
}

.process-subsequent-field-row-create-v7 {
  align-items: end;
}

.process-subsequent-field-row-readonly-v7 .field input,
.process-subsequent-field-row-readonly-v7 .field select {
  background: #eef2fb;
  color: #334155;
}

.process-subsequent-block-v7 .process-field-add-btn {
  margin-top: 12px;
}

.process-subsequent-block-v7 .form-action-row {
  margin-top: 14px;
}

.process-subsequent-empty-v7 {
  margin: 0;
}

@media (max-width: 900px) {
  .process-list-row-v7 {
    grid-template-columns: 1fr;
  }

  .process-subsequent-field-row {
    grid-template-columns: 1fr;
  }
}


/* ###################################################################################
   Aba superior ativa com destaque azul escuro
################################################################################### */

.admin-tab.active,
.admin-tab-link.active,
.admin-top-tab.active,
.top-admin-tab.active,
.nav-tab.active,
.tab-button.active,
.tab-link.active,
[data-admin-tab].active,
[data-settings-admin-tab].active,
a[href*="admin_tab"].active,
button[data-admin-tab].active {
  background: #1f4fa3 !important;
  border-color: #1f4fa3 !important;
  color: #ffffff !important;
  font-weight: 800 !important;
  box-shadow: 0 2px 6px rgba(31, 79, 163, 0.28);
}

.admin-tab.active:hover,
.admin-tab-link.active:hover,
.admin-top-tab.active:hover,
.top-admin-tab.active:hover,
.nav-tab.active:hover,
.tab-button.active:hover,
.tab-link.active:hover,
[data-admin-tab].active:hover,
[data-settings-admin-tab].active:hover,
a[href*="admin_tab"].active:hover,
button[data-admin-tab].active:hover {
  background: #183f82 !important;
  border-color: #183f82 !important;
  color: #ffffff !important;
}

.admin-tab.active *,
.admin-tab-link.active *,
.admin-top-tab.active *,
.top-admin-tab.active *,
.nav-tab.active *,
.tab-button.active *,
.tab-link.active *,
[data-admin-tab].active *,
[data-settings-admin-tab].active *,
a[href*="admin_tab"].active *,
button[data-admin-tab].active * {
  color: #ffffff !important;
}


/* ###################################################################################
   Menu superior - aba ativa com destaque azul escuro V1
################################################################################### */

#submenu-items.menu-tabs .submenu-item.active,
#submenu-items.menu-tabs .submenu-item[aria-selected="true"],
.menu-tabs .submenu-item.active,
.menu-tabs .submenu-item[aria-selected="true"] {
  background: #1f4fa3 !important;
  border: 1px solid #1f4fa3 !important;
  border-bottom-color: #1f4fa3 !important;
  color: #ffffff !important;
  font-weight: 800 !important;
  box-shadow: 0 2px 7px rgba(31, 79, 163, 0.28);
}

#submenu-items.menu-tabs .submenu-item.active:hover,
#submenu-items.menu-tabs .submenu-item[aria-selected="true"]:hover,
.menu-tabs .submenu-item.active:hover,
.menu-tabs .submenu-item[aria-selected="true"]:hover {
  background: #183f82 !important;
  border-color: #183f82 !important;
  color: #ffffff !important;
}

#submenu-items.menu-tabs .submenu-item.active *,
#submenu-items.menu-tabs .submenu-item[aria-selected="true"] *,
.menu-tabs .submenu-item.active *,
.menu-tabs .submenu-item[aria-selected="true"] * {
  color: #ffffff !important;
}

/* //###################################################################################
   (MENU) CAMPOS ADICIONAIS - HIERARQUIA GLOBAL POR SETAS - V1
   //################################################################################### */

.additional-field-row-equalized {
  display: grid;
  grid-template-columns:
    minmax(220px, 1.5fr)
    minmax(180px, 1fr)
    minmax(130px, 0.7fr)
    minmax(110px, 0.6fr)
    minmax(90px, 0.45fr)
    auto;
  gap: 10px;
  align-items: end;
}

.additional-field-hierarchy-col {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  min-height: 38px;
}

.additional-field-hierarchy-col.is-empty {
  visibility: hidden;
}

.header-hierarchy-controls {
  display: flex;
  flex-direction: column;
  gap: 3px;
  align-items: center;
  justify-content: center;
}

.header-hierarchy-label {
  font-size: 10px;
  font-weight: 700;
  line-height: 1;
  text-transform: uppercase;
}

.header-hierarchy-buttons {
  display: flex;
  gap: 4px;
}

.header-hierarchy-btn {
  min-width: 28px;
  min-height: 28px;
  border: 1px solid #c7d2fe;
  border-radius: 6px;
  background: #ffffff;
  cursor: pointer;
  font-weight: 700;
}

.header-hierarchy-btn:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

/* APPVERBO_GLOBAL_PAGE_RESPONSIVE_V1_START */

/* ###################################################################################
   PAGINA GLOBAL - RESPONSIVIDADE DO LAYOUT, CARDS E TABELAS
   ################################################################################### */

html,
body {
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

.layout,
.content,
.container {
  max-width: 100%;
  min-width: 0;
}

.layout {
  width: 100%;
  grid-template-columns: clamp(150px, 18vw, 234px) minmax(0, 1fr);
}

.content {
  padding: clamp(10px, 1.8vw, 24px);
  overflow-x: hidden;
}

.card {
  max-width: 100%;
  min-width: 0;
}

.card,
.entity-panel-card,
.menu-tabs-card {
  overflow-x: auto;
  overflow-y: visible;
  -webkit-overflow-scrolling: touch;
}

.card table,
.entity-panel-card table,
#settings-menu-edit-card table {
  width: 100%;
  min-width: 720px;
  border-collapse: collapse;
}

.card th,
.card td,
.entity-panel-card th,
.entity-panel-card td {
  white-space: nowrap;
}

.card td:last-child,
.entity-panel-card td:last-child,
.card th:last-child,
.entity-panel-card th:last-child {
  width: 1%;
  min-width: 112px;
  white-space: nowrap;
  text-align: center;
}

.table-actions,
.card td:last-child .table-actions,
.entity-panel-card td:last-child .table-actions {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.table-icon-btn,
.card td:last-child .table-icon-btn,
.entity-panel-card td:last-child .table-icon-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  vertical-align: middle;
}

.menu-tabs-card {
  max-width: 100%;
}

.menu-tabs {
  max-width: 100%;
  overflow-x: auto;
  overflow-y: hidden;
  flex-wrap: nowrap;
}

.menu-tabs .submenu-item,
#submenu-items .submenu-item {
  flex: 0 0 auto;
  white-space: nowrap;
}

.topbar,
.topbar-left,
.topbar-right {
  min-width: 0;
}

.brand-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.form-action-row,
.profile-edit-actions,
.entity-create-toolbar {
  max-width: 100%;
  flex-wrap: wrap;
}

input,
select,
textarea {
  max-width: 100%;
  min-width: 0;
}

@media (max-width: 1024px) {
  .layout {
    grid-template-columns: 170px minmax(0, 1fr);
  }

  .content {
    padding: 12px;
  }

  .sidebar {
    min-width: 0;
  }

  .menu-section {
    padding: 0 10px;
    font-size: 11px;
  }

  .menu-item {
    padding: 10px 10px;
    gap: 6px;
    font-size: 13px;
  }

  .menu-icon {
    width: 16px;
  }

  .card {
    padding: 14px;
  }

  .card table,
  .entity-panel-card table,
  #settings-menu-edit-card table {
    min-width: 680px;
  }
}

@media (max-width: 820px) {
  .layout {
    grid-template-columns: 132px minmax(0, 1fr);
  }

  .content {
    padding: 10px;
  }

  .brand-name {
    max-width: 210px;
  }

  .sidebar {
    overflow-x: hidden;
  }

  .menu-section {
    padding: 0 8px;
    font-size: 10px;
  }

  .menu-item {
    padding: 9px 8px;
    gap: 4px;
    font-size: 12px;
  }

  .menu-icon {
    width: 14px;
    font-size: 11px;
  }

  .card {
    padding: 12px;
  }

  .card table,
  .entity-panel-card table,
  #settings-menu-edit-card table {
    min-width: 640px;
  }

  .table-icon-btn {
    width: 30px;
    min-width: 30px;
    height: 30px;
    min-height: 30px;
  }
}

@media (max-width: 640px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }

  .content {
    padding: 8px;
  }

  .topbar {
    padding: 0 10px;
  }

  .brand-name {
    max-width: 160px;
    font-size: 17px;
  }

  .user-name {
    max-width: 100px;
  }

  .card table,
  .entity-panel-card table,
  #settings-menu-edit-card table {
    min-width: 600px;
  }

  .form-action-row .action-btn,
  .form-action-row .action-btn-secondary,
  .form-action-row .action-btn-cancel,
  .profile-edit-actions button {
    width: 100%;
    min-width: 0;
  }
}

/* APPVERBO_GLOBAL_PAGE_RESPONSIVE_V1_END */

/* APPVERBO_PROCESS_FIELDS_CONFIG_LAYOUT_V1_START */

/* ###################################################################################
   ADMINISTRATIVO > MENU > CONFIGURAÇÃO DOS CAMPOS
   Nome do campo e Cabeçalho do campo lado a lado
   ################################################################################### */

.process-fields-config-editor-v1,
.process-fields-config-editor-grid-v1 {
  width: 100% !important;
  max-width: 100% !important;
}

/* O bloco gerado pelo gestor JS deve ser sempre 2 colunas */
.process-fields-picker-row-v4,
.process-fields-config-editor-row-v5,
.process-fields-config-editor-row-v4,
.process-fields-config-editor-row-v3,
.process-fields-config-editor-row-v2 {
  display: grid !important;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
  gap: 12px !important;
  align-items: end !important;
  width: 100% !important;
  max-width: 100% !important;
  grid-column: 1 / -1 !important;
}

/* Cada coluna ocupa somente a sua metade */
.process-fields-picker-row-v4 > *,
.process-fields-config-editor-row-v5 > *,
.process-fields-config-editor-row-v4 > *,
.process-fields-config-editor-row-v3 > *,
.process-fields-config-editor-row-v2 > * {
  min-width: 0 !important;
  width: 100% !important;
  max-width: 100% !important;
}

/* Coluna 1: Nome do campo */
.process-fields-picker-row-v4 > .field,
.process-fields-config-editor-row-v5 > .field,
.process-fields-config-editor-row-v4 > .field,
.process-fields-config-editor-row-v3 > .field,
.process-fields-config-editor-row-v2 > .field {
  grid-column: 1 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 6px !important;
  margin: 0 !important;
}

.process-fields-picker-row-v4 > .field.full,
.process-fields-config-editor-row-v5 > .field.full,
.process-fields-config-editor-row-v4 > .field.full,
.process-fields-config-editor-row-v3 > .field.full,
.process-fields-config-editor-row-v2 > .field.full {
  grid-column: 1 / -1 !important;
}

/* Coluna 2: Cabeçalho do campo */
.process-fields-picker-row-v4 > .process-field-header-picker-v4,
.process-fields-config-editor-row-v5 > .process-field-header-picker-v4,
.process-fields-config-editor-row-v5 > .process-fields-config-header-editor-v5,
.process-fields-config-header-editor-v5,
.process-fields-config-header-editor-v4,
.process-fields-config-header-editor-v3,
.process-fields-config-header-editor-v2,
.process-field-header-picker-v6,
.process-field-header-picker-v5,
.process-field-header-picker-v4,
.process-field-header-picker-v3,
.process-field-header-picker-v2,
.process-field-header-picker-v1 {
  grid-column: 2 !important;
  display: flex !important;
  flex-direction: column !important;
  gap: 6px !important;
  width: 100% !important;
  max-width: 100% !important;
  min-width: 0 !important;
  margin: 0 !important;
}

/* Labels alinhadas */
.process-fields-picker-row-v4 label,
.process-fields-config-editor-row-v5 label,
.process-fields-config-editor-row-v4 label,
.process-fields-config-editor-row-v3 label,
.process-fields-config-editor-row-v2 label,
.process-fields-config-header-editor-v5 label,
.process-fields-config-header-editor-v4 label,
.process-fields-config-header-editor-v3 label,
.process-fields-config-header-editor-v2 label {
  min-height: 14px !important;
  line-height: 14px !important;
  margin: 0 !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  text-transform: uppercase !important;
}

/* Selects com a mesma altura e largura */
.process-fields-picker-row-v4 select,
.process-fields-config-editor-row-v5 select,
.process-fields-config-editor-row-v4 select,
.process-fields-config-editor-row-v3 select,
.process-fields-config-editor-row-v2 select,
.process-fields-config-header-editor-v5 select,
.process-fields-config-header-editor-v4 select,
.process-fields-config-header-editor-v3 select,
.process-fields-config-header-editor-v2 select {
  width: 100% !important;
  min-width: 0 !important;
  max-width: 100% !important;
  height: 38px !important;
  min-height: 38px !important;
  box-sizing: border-box !important;
}

/* Botões sempre abaixo das duas colunas */
.process-fields-config-actions-v5,
.process-fields-config-actions-v4,
.process-fields-config-actions-v3,
.process-fields-config-actions-v2,
.process-fields-config-editor-v1 .form-action-row {
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 8px !important;
  width: 100% !important;
  margin-top: 12px !important;
  grid-column: 1 / -1 !important;
}

/* Evita que qualquer regra global esconda os botões */
.process-fields-config-actions-v5 button,
.process-fields-config-actions-v4 button,
.process-fields-config-actions-v3 button,
.process-fields-config-actions-v2 button,
.process-fields-config-editor-v1 [data-process-fields-config-submit],
.process-fields-config-editor-v1 [data-process-fields-config-cancel] {
  display: inline-flex !important;
  visibility: visible !important;
}

/* Em ecrãs pequenos volta para uma coluna */
@media (max-width: 900px) {
  .process-fields-picker-row-v4,
  .process-fields-config-editor-row-v5,
  .process-fields-config-editor-row-v4,
  .process-fields-config-editor-row-v3,
  .process-fields-config-editor-row-v2 {
    grid-template-columns: 1fr !important;
  }

  .process-fields-picker-row-v4 > .field,
  .process-fields-config-editor-row-v5 > .field,
  .process-fields-config-editor-row-v4 > .field,
  .process-fields-config-editor-row-v3 > .field,
  .process-fields-config-editor-row-v2 > .field,
  .process-fields-picker-row-v4 > .process-field-header-picker-v4,
  .process-fields-config-editor-row-v5 > .process-field-header-picker-v4,
  .process-fields-config-editor-row-v5 > .process-fields-config-header-editor-v5,
  .process-fields-config-header-editor-v5,
  .process-fields-config-header-editor-v4,
  .process-fields-config-header-editor-v3,
  .process-fields-config-header-editor-v2 {
    grid-column: 1 !important;
  }
}

/* APPVERBO_PROCESS_FIELDS_CONFIG_LAYOUT_V1_END */

/* APPVERBO: PROCESS TABS EQUAL WIDTH V1 */
#menu-tabs-card #submenu-items.menu-tabs,
.profile-process-tabs {
  --appverbo-process-tab-equal-width: auto;
}

#menu-tabs-card #submenu-items.menu-tabs {
  align-items: stretch;
}

#menu-tabs-card #submenu-items.menu-tabs .submenu-item,
.profile-process-tabs .profile-process-tab-btn {
  width: var(--appverbo-process-tab-equal-width, auto);
  min-width: var(--appverbo-process-tab-equal-width, auto);
  text-align: center;
  justify-content: center;
}

#menu-tabs-card #submenu-items.menu-tabs .submenu-item {
  display: inline-flex;
  align-items: center;
}

.profile-process-tabs .profile-process-tab-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* APPVERBO_ENTITY_LAYOUT_4_FIELDS_V1_START */
.entity-panel-card .entity-first-row,
.entity-panel-card .entity-second-row,
.entity-panel-card .entity-third-row,
.entity-panel-card .entity-fourth-row,
.entity-panel-card .entity-fifth-row,
.entity-panel-card .entity-scope-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 12px;
}

.entity-panel-card .entity-fifth-row-edit {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.entity-panel-card .entity-first-row .field,
.entity-panel-card .entity-second-row .field,
.entity-panel-card .entity-third-row .field,
.entity-panel-card .entity-fourth-row .field,
.entity-panel-card .entity-fifth-row .field {
  min-width: 0;
  width: 100%;
  max-width: none;
}

.entity-panel-card .entity-first-row input,
.entity-panel-card .entity-first-row select,
.entity-panel-card .entity-second-row input,
.entity-panel-card .entity-second-row select,
.entity-panel-card .entity-third-row input,
.entity-panel-card .entity-third-row select,
.entity-panel-card .entity-fourth-row input,
.entity-panel-card .entity-fourth-row select,
.entity-panel-card .entity-fifth-row input,
.entity-panel-card .entity-fifth-row select {
  width: 100%;
  min-width: 0;
  max-width: 100%;
}

.entity-panel-card .entity-first-row label,
.entity-panel-card .entity-second-row label,
.entity-panel-card .entity-third-row label,
.entity-panel-card .entity-fourth-row label,
.entity-panel-card .entity-fifth-row label {
  white-space: nowrap;
  line-height: 1.2;
}

.entity-panel-card .entity-fifth-row-logo {
  grid-column: span 2;
}

.entity-panel-card .entity-edit-logo-row {
  margin-bottom: 12px;
}

.entity-panel-card .entity-edit-current-logo {
  max-width: 420px;
}

@media (max-width: 1500px) {
  .entity-panel-card .entity-first-row,
  .entity-panel-card .entity-second-row,
  .entity-panel-card .entity-third-row,
  .entity-panel-card .entity-fourth-row,
  .entity-panel-card .entity-fifth-row,
  .entity-panel-card .entity-scope-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .entity-panel-card .entity-fifth-row-logo {
    grid-column: 1 / -1;
  }
}

@media (max-width: 780px) {
  .entity-panel-card .entity-first-row,
  .entity-panel-card .entity-second-row,
  .entity-panel-card .entity-third-row,
  .entity-panel-card .entity-fourth-row,
  .entity-panel-card .entity-fifth-row,
  .entity-panel-card .entity-scope-row {
    grid-template-columns: 1fr;
  }

  .entity-panel-card .entity-fifth-row-logo {
    grid-column: auto;
  }
}
/* APPVERBO_ENTITY_LAYOUT_4_FIELDS_V1_END */



/* APPVERBO_ADMIN_USERS_TABLE_FOOTER_LAYOUT_V10_START */
#admin-users-created-card table,
#inactive-users-card table {
  margin-bottom: 0;
}

#admin-users-created-card .admin-users-table-footer,
#inactive-users-card .admin-users-table-footer {
  align-items: center;
  border-top: 1px solid #d7deeb;
  display: flex;
  gap: 8px;
  justify-content: flex-start;
  margin-top: 12px;
  padding-top: 10px;
}

#admin-users-created-card .admin-users-table-footer select,
#inactive-users-card .admin-users-table-footer select {
  height: 34px;
  margin: 0;
  max-width: 72px;
  min-width: 64px;
  padding: 4px 10px;
  width: auto;
}

#admin-users-created-card .admin-users-table-footer > span,
#inactive-users-card .admin-users-table-footer > span {
  line-height: 34px;
}

#admin-users-created-card .admin-users-table-footer .pagination,
#inactive-users-card .admin-users-table-footer .pagination {
  align-items: center;
  display: flex;
  gap: 6px;
  margin-left: auto;
}

#admin-users-created-card .admin-users-table-footer .pagination button,
#inactive-users-card .admin-users-table-footer .pagination button {
  align-items: center;
  background: #f8fbff;
  border: 1px solid #d8e1ef;
  border-radius: 999px;
  color: #a9b5c7;
  cursor: pointer;
  display: inline-flex;
  font-size: 12px;
  font-weight: 700;
  height: 26px;
  justify-content: center;
  line-height: 1;
  min-width: 26px;
  padding: 0 8px;
}

#admin-users-created-card .admin-users-table-footer .pagination button.active,
#inactive-users-card .admin-users-table-footer .pagination button.active {
  background: #2f66bb;
  border-color: #2f66bb;
  color: #ffffff;
  min-width: 28px;
}

#admin-users-created-card .admin-users-table-footer .pagination button:disabled,
#inactive-users-card .admin-users-table-footer .pagination button:disabled {
  background: #f8fbff;
  border-color: #d8e1ef;
  color: #c4cedb;
  cursor: not-allowed;
  opacity: 1;
}
/* APPVERBO_ADMIN_USERS_TABLE_FOOTER_LAYOUT_V10_END */

