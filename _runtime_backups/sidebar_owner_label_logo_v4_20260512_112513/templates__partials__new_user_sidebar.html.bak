    {% set menu_icons = {
      "home": "[H]",
      "administrativo": "[*]",
      "meu_perfil": "[D]",
      "funcionarios": "[F]",
      "financeiro": "[$]",
      "relatorios": "[R]",
      "links": "[L]",
      "contato": "[C]",
      "tutorial": "[T]",
      "tesouraria": "[T]"
    } %}

    {# APPVERBO_SIDEBAR_DYNAMIC_SECTIONS_ORDER_V1_START #}
    {% set fallback_sidebar_sections = [
      ("sistema", "Sistema"),
      ("geral", "Geral"),
      ("dados_gerais", "Dados gerais"),
      ("igreja", "Igreja"),
      ("tesouraria", "Tesouraria")
    ] %}

    {% set dynamic_sidebar_sections = namespace(items=[]) %}

    {% if sidebar_section_options is defined and sidebar_section_options %}
      {% for section in sidebar_section_options %}
        {% set section_key = section.key|default("", true)|lower %}
        {% set section_label = section.label|default(section_key, true) %}

        {% if section_key %}
          {% set dynamic_sidebar_sections.items = dynamic_sidebar_sections.items + [(section_key, section_label)] %}
        {% endif %}
      {% endfor %}
    {% endif %}

    {% set sidebar_sections = dynamic_sidebar_sections.items if dynamic_sidebar_sections.items else fallback_sidebar_sections %}
    {# APPVERBO_SIDEBAR_DYNAMIC_SECTIONS_ORDER_V1_END #}

    <aside class="sidebar">
      {% for section_key, section_label in sidebar_sections %}
        {% set section_state = namespace(has_items=false) %}

        {% for setting in sidebar_menu_settings %}
          {% set current_section = setting.menu_section|default("", true) %}

          {% if not current_section %}
            {% if setting.key == "administrativo" %}
              {% set current_section = "sistema" %}
            {% elif setting.key == "home" %}
              {% set current_section = "geral" %}
            {% else %}
              {% set current_section = "igreja" %}
            {% endif %}
          {% endif %}

          {% if setting.key in visible_sidebar_menu_keys and current_section == section_key %}
            {% set section_state.has_items = true %}
          {% endif %}
        {% endfor %}

        {% if section_state.has_items %}
          <div class="menu-section">{{ section_label }}</div>
          <nav class="menu-list" aria-label="Menu {{ section_label|lower }}">
            {% for setting in sidebar_menu_settings %}
              {% set current_section = setting.menu_section|default("", true) %}

              {% if not current_section %}
                {% if setting.key == "administrativo" %}
                  {% set current_section = "sistema" %}
                {% elif setting.key == "home" %}
                  {% set current_section = "geral" %}
                {% else %}
                  {% set current_section = "igreja" %}
                {% endif %}
              {% endif %}

              {% if setting.key in visible_sidebar_menu_keys and current_section == section_key %}
                <button
                  type="button"
                  class="menu-item{% if setting.key|lower == initial_menu %} active{% endif %}"
                  data-menu="{{ setting.key|lower }}"
                >
                  <span class="menu-icon">{{ menu_icons.get(setting.key, "[+]") }}</span>
                  <span>{{ setting.label }}</span>
                </button>
              {% endif %}
            {% endfor %}
          </nav>
        {% endif %}
      {% endfor %}
    {# APPVERBO_SIDEBAR_OWNER_ENTITY_LABEL_V3_START #}
{% set sidebar_owner_name = "" %}
{% set sidebar_owner_logo_url = "" %}

{% if sidebar_owner_entity is defined and sidebar_owner_entity %}
    {% set sidebar_owner_name = sidebar_owner_entity.name if sidebar_owner_entity.name else "" %}
    {% set sidebar_owner_logo_url = sidebar_owner_entity.logo_url if sidebar_owner_entity.logo_url else "" %}
{% endif %}

{% if not sidebar_owner_name and user_personal_data is defined and user_personal_data %}
    {% set sidebar_owner_name = user_personal_data.primary_entity_name if user_personal_data.primary_entity_name is defined and user_personal_data.primary_entity_name else "" %}
{% endif %}

{% if not sidebar_owner_logo_url and user_personal_data is defined and user_personal_data %}
    {% set sidebar_owner_logo_url = user_personal_data.primary_entity_logo_url if user_personal_data.primary_entity_logo_url is defined and user_personal_data.primary_entity_logo_url else "" %}
{% endif %}

{% if sidebar_owner_name or sidebar_owner_logo_url %}
<div class="sidebar-address-card appverbo-sidebar-owner-card" data-sidebar-owner-entity="1">
    <div class="appverbo-sidebar-owner-logo-box">
        {% if sidebar_owner_logo_url %}
        <img class="appverbo-sidebar-owner-logo" src="{{ sidebar_owner_logo_url }}" alt="Logo da entidade owner">
        {% else %}
        <span class="appverbo-sidebar-owner-logo-placeholder" aria-hidden="true">
            {{ (sidebar_owner_name|string)[:1]|upper if sidebar_owner_name else "O" }}
        </span>
        {% endif %}
    </div>
    <div class="appverbo-sidebar-owner-text">
        <span class="sidebar-address-label appverbo-sidebar-owner-label">Entidade Owner</span>
        <strong class="sidebar-address-title appverbo-sidebar-owner-name">{{ sidebar_owner_name }}</strong>
    </div>
</div>
{% endif %}
{# APPVERBO_SIDEBAR_OWNER_ENTITY_LABEL_V3_END #}
</aside>
