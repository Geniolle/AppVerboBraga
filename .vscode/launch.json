{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AppVerboBraga: FastAPI Local",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "appverbo.app:create_app",
        "--factory",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "jinja": true,
      "justMyCode": true,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}\\.env"
    }
  ]
}
