// APPVERBO_SETTINGS_SYSTEM_FIELDS_V1_START
(function () {
  "use strict";

  //###################################################################################
  // (1) CAMPOS DE SISTEMA DO PROCESSO MEU PERFIL
  //###################################################################################

  const CAMPOS_SISTEMA_MEU_PERFIL_V1 = [
    { key: "nome", label: "Nome", typeLabel: "Texto", requiredLabel: "Sim", sizeLabel: "200", listLabel: "-", group: "Dados pessoais" },
    { key: "telefone", label: "Telefone", typeLabel: "Texto", requiredLabel: "Sim", sizeLabel: "30", listLabel: "-", group: "Dados pessoais" },
    { key: "email", label: "Email", typeLabel: "Email", requiredLabel: "Sim", sizeLabel: "150", listLabel: "-", group: "Dados pessoais" },
    { key: "pais", label: "Pais", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "120", listLabel: "-", group: "Dados pessoais" },
    { key: "data_nascimento", label: "Data de nascimento", typeLabel: "Data", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" },
    { key: "whatsapp", label: "WhatsApp", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "20", listLabel: "-", group: "Dados pessoais" },
    { key: "autorizacao_whatsapp", label: "Autorizacao para avisos por WhatsApp", typeLabel: "Flag", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" },
    { key: "conta", label: "Conta", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "20", listLabel: "-", group: "Dados pessoais" },
    { key: "estado_membro", label: "Estado de membro", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "20", listLabel: "-", group: "Dados pessoais" },
    { key: "colaborador", label: "Colaborador", typeLabel: "Flag", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" },
    { key: "entidades", label: "Entidades", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" },
    { key: "ultima_verificacao_whatsapp", label: "Ultima verificacao WhatsApp", typeLabel: "Data", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" },
    { key: "detalhe_verificacao", label: "Detalhe da verificacao", typeLabel: "Texto", requiredLabel: "Nao", sizeLabel: "-", listLabel: "-", group: "Dados pessoais" }
  ];

  //###################################################################################
  // (2) NORMALIZACAO E LOCALIZACAO DA PAGINA
  //###################################################################################

  function normalizarTextoSistemaMeuPerfil_v1(valor) {
    return String(valor || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim()
      .toLowerCase();
  }

  function obterParametroUrlSistemaMeuPerfil_v1(nome) {
    const params = new URLSearchParams(window.location.search || "");
    return String(params.get(nome) || "").trim().toLowerCase();
  }

  function paginaConfiguracaoMeuPerfil_v1() {
    const settingsEditKey = obterParametroUrlSistemaMeuPerfil_v1("settings_edit_key");
    const settingsTab = obterParametroUrlSistemaMeuPerfil_v1("settings_tab");
    const textoPagina = normalizarTextoSistemaMeuPerfil_v1(document.body && document.body.textContent);

    if (settingsEditKey === "meu_perfil" && (!settingsTab || settingsTab === "campos-adicionais")) {
      return true;
    }

    return textoPagina.includes("editar processo: meu perfil") &&
      textoPagina.includes("campos adicionais") &&
      textoPagina.includes("campos criados");
  }

  //###################################################################################
  // (3) LOCALIZAR TABELA CAMPOS CRIADOS
  //###################################################################################

  function localizarTabelaCamposCriadosMeuPerfil_v1() {
    const titulos = Array.from(document.querySelectorAll("h2, h3, h4, strong, p, div"));

    for (const titulo of titulos) {
      const texto = normalizarTextoSistemaMeuPerfil_v1(titulo.textContent);

      if (texto === "campos criados" || texto.includes("campos criados")) {
        const bloco = titulo.closest(".card, section, div") || titulo.parentElement;

        if (bloco) {
          const tabela = bloco.querySelector("table");

          if (tabela && tabela.querySelector("tbody")) {
            return tabela;
          }
        }
      }
    }

    const tabelas = Array.from(document.querySelectorAll("table"));

    return tabelas.find(function (tabela) {
      const texto = normalizarTextoSistemaMeuPerfil_v1(tabela.textContent);
      return texto.includes("nome do campo adicional") && texto.includes("tipo do campo");
    }) || null;
  }

  function obterCamposExistentesMeuPerfil_v1(tbody) {
    const existentes = new Set();

    Array.from(tbody.querySelectorAll("tr")).forEach(function (linha) {
      const primeiraCelula = linha.querySelector("td");

      if (!primeiraCelula) {
        return;
      }

      const texto = normalizarTextoSistemaMeuPerfil_v1(primeiraCelula.textContent);

      if (texto) {
        existentes.add(texto);
      }
    });

    return existentes;
  }

  //###################################################################################
  // (4) CRIAR LINHAS NAO EDITAVEIS
  //###################################################################################

  function criarCelulaSistemaMeuPerfil_v1(texto) {
    const td = document.createElement("td");
    td.textContent = texto || "-";
    return td;
  }

  function criarCelulaAcoesSistemaMeuPerfil_v1() {
    const td = document.createElement("td");
    const badge = document.createElement("span");

    badge.className = "appverbo-system-field-badge-v1";
    badge.textContent = "Sistema";
    badge.title = "Campo de sistema: nao pode ser editado, ordenado ou eliminado.";

    td.appendChild(badge);

    return td;
  }

  function criarLinhaSistemaMeuPerfil_v1(campo) {
    const tr = document.createElement("tr");

    tr.className = "appverbo-system-field-row-v1";
    tr.dataset.systemFieldKeyV1 = campo.key;

    tr.appendChild(criarCelulaSistemaMeuPerfil_v1(campo.label));
    tr.appendChild(criarCelulaSistemaMeuPerfil_v1(campo.typeLabel));
    tr.appendChild(criarCelulaSistemaMeuPerfil_v1(campo.requiredLabel));
    tr.appendChild(criarCelulaSistemaMeuPerfil_v1(campo.sizeLabel));
    tr.appendChild(criarCelulaSistemaMeuPerfil_v1(campo.listLabel));
    tr.appendChild(criarCelulaAcoesSistemaMeuPerfil_v1());

    return tr;
  }

  function inserirNotaSistemaMeuPerfil_v1(tabela) {
    const bloco = tabela.closest(".card, section, div");

    if (!bloco || bloco.querySelector(".appverbo-system-field-note-v1")) {
      return;
    }

    const nota = document.createElement("p");
    nota.className = "appverbo-system-field-note-v1";
    nota.textContent = "Campos de sistema sao exibidos apenas para referencia e nao podem ser editados, ordenados ou eliminados.";

    bloco.insertBefore(nota, tabela.parentElement || tabela);
  }

  function instalarEstiloSistemaMeuPerfil_v1() {
    if (document.getElementById("appverbo-system-fields-style-v1")) {
      return;
    }

    const style = document.createElement("style");
    style.id = "appverbo-system-fields-style-v1";
    style.textContent = [
      ".appverbo-system-field-row-v1 td { background: #f8fafc; color: #334155; }",
      ".appverbo-system-field-row-v1 td:first-child { font-weight: 700; }",
      ".appverbo-system-field-badge-v1 { display: inline-flex; align-items: center; justify-content: center; min-width: 70px; padding: 5px 8px; border-radius: 8px; border: 1px solid #cbd5e1; background: #e2e8f0; color: #334155; font-size: 11px; font-weight: 700; }",
      ".appverbo-system-field-note-v1 { margin: 8px 0 12px; color: #475569; font-size: 12px; }"
    ].join("\\n");

    document.head.appendChild(style);
  }

  //###################################################################################
  // (5) APLICAR CAMPOS NA TABELA
  //###################################################################################

  function aplicarCamposSistemaMeuPerfil_v1() {
    if (!paginaConfiguracaoMeuPerfil_v1()) {
      return;
    }

    const tabela = localizarTabelaCamposCriadosMeuPerfil_v1();

    if (!tabela) {
      return;
    }

    const tbody = tabela.querySelector("tbody");

    if (!tbody) {
      return;
    }

    instalarEstiloSistemaMeuPerfil_v1();
    inserirNotaSistemaMeuPerfil_v1(tabela);

    const existentes = obterCamposExistentesMeuPerfil_v1(tbody);

    CAMPOS_SISTEMA_MEU_PERFIL_V1
      .slice()
      .reverse()
      .forEach(function (campo) {
        const labelNormalizado = normalizarTextoSistemaMeuPerfil_v1(campo.label);

        if (existentes.has(labelNormalizado)) {
          return;
        }

        tbody.insertBefore(criarLinhaSistemaMeuPerfil_v1(campo), tbody.firstChild);
        existentes.add(labelNormalizado);
      });
  }

  //###################################################################################
  // (6) INICIAR
  //###################################################################################

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", aplicarCamposSistemaMeuPerfil_v1);
  }
  else {
    aplicarCamposSistemaMeuPerfil_v1();
  }

  window.addEventListener("pageshow", aplicarCamposSistemaMeuPerfil_v1);
})();
// APPVERBO_SETTINGS_SYSTEM_FIELDS_V1_END
