// APPVERBO_PROFILE_FIELD_ORDER_V3_START
//###################################################################################
// (1) ORDENAR MODO EDICAO CONFORME MODO LEITURA DO MEU PERFIL
//###################################################################################

(function () {
  "use strict";

  //###################################################################################
  // (2) CONSTANTES E NORMALIZACAO
  //###################################################################################

  const bootstrap = window.__APPVERBO_BOOTSTRAP__ || {};

  const fallbackVisibleFields = Array.isArray(bootstrap.profilePersonalVisibleFields)
    ? bootstrap.profilePersonalVisibleFields
      .map((fieldKey) => String(fieldKey || "").trim().toLowerCase())
      .filter(Boolean)
    : [];

  const profilePersonalFieldLabels = (
    bootstrap.profilePersonalFieldLabels &&
    typeof bootstrap.profilePersonalFieldLabels === "object" &&
    !Array.isArray(bootstrap.profilePersonalFieldLabels)
  )
    ? bootstrap.profilePersonalFieldLabels
    : {};

  const builtinLabelByKey = {
    nome: "Nome",
    email: "Email",
    telefone: "Telefone",
    pais: "País",
    data_nascimento: "Data de nascimento",
    whatsapp: "WhatsApp",
    autorizacao_whatsapp: "Autorização para avisos por WhatsApp",
    conta: "Conta",
    estado_membro: "Estado de membro",
    colaborador: "Colaborador",
    entidades: "Entidades",
    ultima_verificacao_whatsapp: "Última verificação WhatsApp",
    detalhe_verificacao: "Detalhe da verificação"
  };

  const builtinKeyByInputName = {
    full_name: "nome",
    primary_phone: "telefone",
    login_email: "email",
    email: "email",
    country: "pais",
    birth_date: "data_nascimento",
    whatsapp_notice_opt_in: "autorizacao_whatsapp"
  };

  function normalizeKey_v3(value) {
    return String(value || "").trim().toLowerCase();
  }

  function normalizeLookup_v3(value) {
    return String(value || "")
      .trim()
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/\*/g, "")
      .replace(/\s+/g, " ");
  }

  //###################################################################################
  // (3) MAPEAR LABEL PARA KEY
  //###################################################################################

  function buildLabelToKeyMap_v3() {
    const labelToKey = new Map();

    Object.keys(builtinLabelByKey).forEach(function (fieldKey) {
      labelToKey.set(normalizeLookup_v3(builtinLabelByKey[fieldKey]), fieldKey);
    });

    Object.keys(profilePersonalFieldLabels).forEach(function (fieldKey) {
      const cleanFieldKey = normalizeKey_v3(fieldKey);
      const label = String(profilePersonalFieldLabels[fieldKey] || "").trim();

      if (cleanFieldKey && label) {
        labelToKey.set(normalizeLookup_v3(label), cleanFieldKey);
      }
    });

    return labelToKey;
  }

  function resolveKeyByLabel_v3(labelText) {
    const labelToKey = buildLabelToKeyMap_v3();
    return labelToKey.get(normalizeLookup_v3(labelText)) || "";
  }

  //###################################################################################
  // (4) LOCALIZAR ELEMENTOS
  //###################################################################################

  function getProfileCard_v3() {
    return document.querySelector("#perfil-pessoal-card");
  }

  function getReadonlyGrid_v3() {
    const card = getProfileCard_v3();

    if (!card) {
      return null;
    }

    return card.querySelector(".profile-readonly .personal-grid");
  }

  function getEditForm_v3() {
    return (
      document.querySelector('form[action="/users/profile/personal"]') ||
      document.querySelector("#perfil-pessoal-card form.profile-edit-form")
    );
  }

  function getEditGrid_v3(form) {
    if (!form) {
      return null;
    }

    return form.querySelector(".personal-grid") || form;
  }

  //###################################################################################
  // (5) OBTER ORDEM REAL DO MODO LEITURA
  //###################################################################################

  function resolveReadonlyItemKey_v3(item) {
    if (!item) {
      return "";
    }

    const explicitKey = normalizeKey_v3(
      item.getAttribute("data-profile-field-key") ||
      item.dataset.profileFieldKey ||
      ""
    );

    if (explicitKey) {
      return explicitKey;
    }

    const labelElement = item.querySelector(".personal-label");
    const labelText = labelElement ? labelElement.textContent : "";

    return resolveKeyByLabel_v3(labelText);
  }

  function getReadonlyOrder_v3() {
    const readonlyGrid = getReadonlyGrid_v3();
    const order = [];
    const seen = new Set();

    if (!readonlyGrid) {
      return order;
    }

    Array.from(readonlyGrid.querySelectorAll(".personal-item")).forEach(function (item) {
      const fieldKey = resolveReadonlyItemKey_v3(item);

      if (!fieldKey || seen.has(fieldKey)) {
        return;
      }

      seen.add(fieldKey);
      order.push(fieldKey);
    });

    return order;
  }

  function mergeOrder_v3(primaryOrder, fallbackOrder) {
    const result = [];
    const seen = new Set();

    primaryOrder.concat(fallbackOrder).forEach(function (rawFieldKey) {
      const fieldKey = normalizeKey_v3(rawFieldKey);

      if (!fieldKey || seen.has(fieldKey)) {
        return;
      }

      seen.add(fieldKey);
      result.push(fieldKey);
    });

    return result;
  }

  function getEffectiveOrder_v3() {
    const readonlyOrder = getReadonlyOrder_v3();

    if (readonlyOrder.length) {
      return mergeOrder_v3(readonlyOrder, fallbackVisibleFields);
    }

    return fallbackVisibleFields.slice();
  }

  //###################################################################################
  // (6) IDENTIFICAR CAMPOS DO FORMULARIO
  //###################################################################################

  function resolveEditFieldKey_v3(field) {
    if (!field) {
      return "";
    }

    const explicitKey = normalizeKey_v3(
      field.getAttribute("data-profile-field-key") ||
      field.dataset.profileFieldKey ||
      ""
    );

    if (explicitKey) {
      return explicitKey;
    }

    const customInput = field.querySelector('[name^="custom_field__"]');

    if (customInput) {
      return normalizeKey_v3(
        String(customInput.getAttribute("name") || "").replace(/^custom_field__/, "")
      );
    }

    const input = field.querySelector("input, select, textarea");

    if (input) {
      const inputName = normalizeKey_v3(input.getAttribute("name") || "");

      if (builtinKeyByInputName[inputName]) {
        return builtinKeyByInputName[inputName];
      }
    }

    const label = field.querySelector("label");

    if (label) {
      return resolveKeyByLabel_v3(label.textContent);
    }

    return "";
  }

  function findEditFieldByKey_v3(form, fieldKey) {
    const cleanFieldKey = normalizeKey_v3(fieldKey);

    if (!form || !cleanFieldKey) {
      return null;
    }

    const allFields = Array.from(form.querySelectorAll(".field"));

    return allFields.find(function (field) {
      return resolveEditFieldKey_v3(field) === cleanFieldKey;
    }) || null;
  }

  //###################################################################################
  // (7) APLICAR ORDEM AO FORMULARIO
  //###################################################################################

  function applyOrderToEditForm_v3() {
    const form = getEditForm_v3();
    const editGrid = getEditGrid_v3(form);
    const effectiveOrder = getEffectiveOrder_v3();

    if (!form || !editGrid || !effectiveOrder.length) {
      return;
    }

    const orderedKeys = new Set();

    Array.from(editGrid.querySelectorAll(".field")).forEach(function (field) {
      field.style.order = "";
    });

    effectiveOrder.forEach(function (fieldKey, index) {
      const field = findEditFieldByKey_v3(form, fieldKey);

      if (!field || field.parentElement !== editGrid) {
        return;
      }

      field.style.order = String((index + 1) * 10);
      field.setAttribute("data-appverbo-profile-order-v3", String(index + 1));
      orderedKeys.add(fieldKey);
    });

    let nextOrder = (effectiveOrder.length + 1) * 10;

    Array.from(editGrid.querySelectorAll(".field")).forEach(function (field) {
      const fieldKey = resolveEditFieldKey_v3(field);

      if (fieldKey && orderedKeys.has(fieldKey)) {
        return;
      }

      field.style.order = String(nextOrder);
      field.setAttribute("data-appverbo-profile-order-v3", String(nextOrder));
      nextOrder += 10;
    });

    const actions = form.querySelector(".profile-edit-actions");

    if (actions) {
      actions.style.order = String(nextOrder + 10);
    }
  }

  //###################################################################################
  // (8) OBSERVAR BOTAO EDITAR
  //###################################################################################

  function installEditClickHook_v3() {
    document.addEventListener("click", function (event) {
      const button = event.target && event.target.closest
        ? event.target.closest('[data-edit-target="perfil-pessoal-card"], .profile-edit-toggle')
        : null;

      if (!button) {
        return;
      }

      window.setTimeout(applyOrderToEditForm_v3, 0);
      window.setTimeout(applyOrderToEditForm_v3, 80);
      window.setTimeout(applyOrderToEditForm_v3, 250);
    }, true);
  }

  function installMutationObserver_v3() {
    const card = getProfileCard_v3();

    if (!card || typeof MutationObserver === "undefined") {
      return;
    }

    const observer = new MutationObserver(function () {
      applyOrderToEditForm_v3();
    });

    observer.observe(card, {
      attributes: true,
      childList: true,
      subtree: true,
      attributeFilter: ["class", "style"]
    });
  }

  //###################################################################################
  // (9) INICIAR
  //###################################################################################

  function init_v3() {
    installEditClickHook_v3();
    installMutationObserver_v3();

    applyOrderToEditForm_v3();
    window.setTimeout(applyOrderToEditForm_v3, 100);
    window.setTimeout(applyOrderToEditForm_v3, 400);
    window.setTimeout(applyOrderToEditForm_v3, 1000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init_v3);
  }
  else {
    init_v3();
  }

  window.addEventListener("pageshow", init_v3);
  window.reorderMeuPerfilProfileFields = applyOrderToEditForm_v3;
})();
// APPVERBO_PROFILE_FIELD_ORDER_V3_END
