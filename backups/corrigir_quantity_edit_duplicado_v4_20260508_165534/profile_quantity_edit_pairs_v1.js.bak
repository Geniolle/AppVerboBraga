// APPVERBO_PROFILE_QUANTITY_EDIT_PAIRS_V3_START
(function () {
  "use strict";

  //###################################################################################
  // (1) BOOTSTRAP E CONSTANTES
  //###################################################################################

  const bootstrap = window.__APPVERBO_BOOTSTRAP__ || {};
  const MEU_PERFIL_KEY_V3 = "meu_perfil";
  const LEGACY_DOCUMENTOS_KEY_V3 = "documentos";

  const sidebarMenuSettings = Array.isArray(bootstrap.sidebarMenuSettings)
    ? bootstrap.sidebarMenuSettings
    : [];

  const menuProcessQuantityValuesMap = (
    bootstrap.menuProcessQuantityValuesMap &&
    typeof bootstrap.menuProcessQuantityValuesMap === "object" &&
    !Array.isArray(bootstrap.menuProcessQuantityValuesMap)
  )
    ? bootstrap.menuProcessQuantityValuesMap
    : {};

  const renderStateByRuleKey = new Map();

  //###################################################################################
  // (2) NORMALIZAÇÃO
  //###################################################################################

  function normalizeKeyQuantityEditPairs_v3(value) {
    const cleanValue = String(value || "")
      .trim()
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/[^a-z0-9_]+/g, "_")
      .replace(/_+/g, "_")
      .replace(/^_|_$/g, "");

    if (cleanValue === LEGACY_DOCUMENTOS_KEY_V3) {
      return MEU_PERFIL_KEY_V3;
    }

    return cleanValue;
  }

  function normalizeTextQuantityEditPairs_v3(value) {
    return String(value || "")
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "")
      .trim()
      .toLowerCase()
      .replace(/\s+/g, " ");
  }

  function toSentenceCaseQuantityEditPairs_v3(value) {
    const cleanText = String(value || "").trim().replace(/\s+/g, " ");

    if (!cleanText) {
      return "";
    }

    const loweredText = cleanText.toLocaleLowerCase("pt-PT");
    return loweredText.charAt(0).toLocaleUpperCase("pt-PT") + loweredText.slice(1);
  }

  function normalizeFieldTypeQuantityEditPairs_v3(value) {
    const cleanType = String(value || "text").trim().toLowerCase();
    const allowedTypes = new Set(["text", "number", "email", "phone", "date", "flag", "list"]);

    return allowedTypes.has(cleanType) ? cleanType : "text";
  }

  function convertDisplayDateToInputDateQuantityEditPairs_v3(value) {
    const cleanValue = String(value || "").trim();

    if (/^\d{4}-\d{2}-\d{2}$/.test(cleanValue)) {
      return cleanValue;
    }

    if (/^\d{2}\/\d{2}\/\d{4}$/.test(cleanValue)) {
      const parts = cleanValue.split("/");
      return parts[2] + "-" + parts[1] + "-" + parts[0];
    }

    return cleanValue;
  }

  //###################################################################################
  // (3) CONFIGURAÇÃO DO MEU PERFIL
  //###################################################################################

  function getMeuPerfilSettingQuantityEditPairs_v3() {
    return sidebarMenuSettings.find(function (setting) {
      return normalizeKeyQuantityEditPairs_v3(setting && setting.key) === MEU_PERFIL_KEY_V3;
    }) || null;
  }

  function getFieldMetaMapQuantityEditPairs_v3(setting) {
    const metaMap = new Map();

    const options = Array.isArray(setting && setting.process_field_options)
      ? setting.process_field_options
      : [];

    options.forEach(function (option) {
      const fieldKey = normalizeKeyQuantityEditPairs_v3(option && option.key);

      if (!fieldKey) {
        return;
      }

      metaMap.set(fieldKey, {
        key: fieldKey,
        label: toSentenceCaseQuantityEditPairs_v3(option.label || fieldKey),
        fieldType: normalizeFieldTypeQuantityEditPairs_v3(option.field_type),
        isRequired: Boolean(option.is_required || option.required),
        listOptions: Array.isArray(option.list_options) ? option.list_options : []
      });
    });

    return metaMap;
  }

  function normalizeQuantityRulesQuantityEditPairs_v3(rawRules) {
    if (!Array.isArray(rawRules)) {
      return [];
    }

    return rawRules
      .map(function (rawRule, index) {
        if (!rawRule || typeof rawRule !== "object") {
          return null;
        }

        const key = normalizeKeyQuantityEditPairs_v3(
          rawRule.key ||
          rawRule.rule_key ||
          rawRule.ruleKey ||
          "qty_regra_" + String(index + 1)
        );

        const quantityFieldKey = normalizeKeyQuantityEditPairs_v3(
          rawRule.quantity_field_key ||
          rawRule.quantityFieldKey
        );

        const repeatedRaw = Array.isArray(rawRule.repeated_field_keys || rawRule.repeatedFieldKeys)
          ? (rawRule.repeated_field_keys || rawRule.repeatedFieldKeys)
          : [];

        const repeatedFieldKeys = [];
        const seen = new Set();

        repeatedRaw.forEach(function (rawFieldKey) {
          const fieldKey = normalizeKeyQuantityEditPairs_v3(rawFieldKey);

          if (!fieldKey || seen.has(fieldKey)) {
            return;
          }

          seen.add(fieldKey);
          repeatedFieldKeys.push(fieldKey);
        });

        const parsedMax = Number.parseInt(String(rawRule.max_items || rawRule.maxItems || "50"), 10);

        if (!key || !quantityFieldKey || !repeatedFieldKeys.length) {
          return null;
        }

        return {
          key: key,
          label: toSentenceCaseQuantityEditPairs_v3(rawRule.label || rawRule.rule_label || rawRule.name || "Quantidade"),
          quantityFieldKey: quantityFieldKey,
          repeatedFieldKeys: repeatedFieldKeys,
          headerKey: normalizeKeyQuantityEditPairs_v3(rawRule.header_key || rawRule.headerKey),
          itemLabel: toSentenceCaseQuantityEditPairs_v3(rawRule.item_label || rawRule.itemLabel || "Item") || "Item",
          maxItems: Number.isFinite(parsedMax) ? Math.max(1, Math.min(parsedMax, 50)) : 50
        };
      })
      .filter(Boolean);
  }

  function normalizeQuantityItemsQuantityEditPairs_v3(rawItems) {
    if (!Array.isArray(rawItems)) {
      return [];
    }

    return rawItems
      .map(function (rawItem) {
        if (!rawItem || typeof rawItem !== "object") {
          return null;
        }

        const normalized = {};

        Object.keys(rawItem).forEach(function (rawKey) {
          const fieldKey = normalizeKeyQuantityEditPairs_v3(rawKey);

          if (!fieldKey) {
            return;
          }

          normalized[fieldKey] = String(rawItem[rawKey] || "").trim();
        });

        return normalized;
      })
      .filter(Boolean);
  }

  function getQuantityValuesQuantityEditPairs_v3(ruleKey) {
    const valuesByMenu = menuProcessQuantityValuesMap[MEU_PERFIL_KEY_V3];

    if (!valuesByMenu || typeof valuesByMenu !== "object" || Array.isArray(valuesByMenu)) {
      return [];
    }

    return normalizeQuantityItemsQuantityEditPairs_v3(valuesByMenu[normalizeKeyQuantityEditPairs_v3(ruleKey)]);
  }

  //###################################################################################
  // (4) DETETAR ABA/SEÇÃO ATIVA DO MEU PERFIL
  //###################################################################################

  function getCurrentProfileSectionFromUrlQuantityEditPairs_v3() {
    try {
      const url = new URL(window.location.href);
      return normalizeKeyQuantityEditPairs_v3(url.searchParams.get("profile_section") || "");
    }
    catch (error) {
      return "";
    }
  }

  function getCurrentProfileSectionFromInputQuantityEditPairs_v3() {
    const sectionInput = document.querySelector("[data-meu-perfil-section-input]");

    if (!sectionInput) {
      return "";
    }

    return normalizeKeyQuantityEditPairs_v3(sectionInput.value || "");
  }

  function getCurrentProfileSectionFromActiveTabQuantityEditPairs_v3() {
    const candidates = Array.from(
      document.querySelectorAll("button, a, [role='tab'], .menu-tab, .tab-button, .active")
    );

    const activeCandidate = candidates.find(function (element) {
      const text = normalizeTextQuantityEditPairs_v3(element.textContent || "");
      const className = normalizeTextQuantityEditPairs_v3(element.className || "");
      const ariaSelected = String(element.getAttribute("aria-selected") || "").trim().toLowerCase();

      if (!text) {
        return false;
      }

      if (!(className.includes("active") || ariaSelected === "true")) {
        return false;
      }

      return text.includes("dados pessoais") || text.includes("dados de agregados");
    });

    const activeText = normalizeTextQuantityEditPairs_v3(activeCandidate ? activeCandidate.textContent : "");

    if (activeText.includes("agregados")) {
      return "custom_dados_de_agregados";
    }

    if (activeText.includes("pessoais")) {
      return "custom_dados_pessoais";
    }

    return "";
  }

  function getCurrentProfileSectionQuantityEditPairs_v3() {
    return getCurrentProfileSectionFromInputQuantityEditPairs_v3() ||
      getCurrentProfileSectionFromUrlQuantityEditPairs_v3() ||
      getCurrentProfileSectionFromActiveTabQuantityEditPairs_v3();
  }

  function shouldRenderRuleInCurrentSectionQuantityEditPairs_v3(rule) {
    const currentSection = getCurrentProfileSectionQuantityEditPairs_v3();
    const ruleSection = normalizeKeyQuantityEditPairs_v3(rule && rule.headerKey);

    if (!ruleSection) {
      return true;
    }

    if (!currentSection) {
      return false;
    }

    return currentSection === ruleSection;
  }

  //###################################################################################
  // (5) LOCALIZAR FORMULÁRIO
  //###################################################################################

  function getEditFormQuantityEditPairs_v3() {
    return (
      document.querySelector('form[action="/users/profile/personal"]') ||
      document.querySelector("#perfil-pessoal-card form.profile-edit-form") ||
      document.querySelector("#perfil-pessoal-card form")
    );
  }

  function getEditGridQuantityEditPairs_v3(form) {
    if (!form) {
      return null;
    }

    return form.querySelector(".personal-grid") ||
      form.querySelector(".form-grid") ||
      form;
  }

  function isEditFormVisibleQuantityEditPairs_v3(form) {
    if (!form) {
      return false;
    }

    const style = window.getComputedStyle(form);
    return style.display !== "none" && style.visibility !== "hidden";
  }

  function getFieldLabelQuantityEditPairs_v3(field) {
    const label = field ? field.querySelector("label, .personal-label") : null;
    return normalizeTextQuantityEditPairs_v3(label ? label.textContent : "");
  }

  function findFieldWrapperByFieldKeyQuantityEditPairs_v3(form, fieldKey, fieldMetaMap) {
    const cleanFieldKey = normalizeKeyQuantityEditPairs_v3(fieldKey);

    if (!form || !cleanFieldKey) {
      return null;
    }

    const directSelectors = [
      '[name="custom_field__' + cleanFieldKey + '"]',
      '[name="' + cleanFieldKey + '"]',
      '[data-profile-field-key="' + cleanFieldKey + '"]'
    ];

    for (const selector of directSelectors) {
      const input = form.querySelector(selector);

      if (input) {
        return input.closest(".field") || input.parentElement;
      }
    }

    const meta = fieldMetaMap.get(cleanFieldKey);
    const expectedLabel = normalizeTextQuantityEditPairs_v3(meta ? meta.label : cleanFieldKey);

    return Array.from(form.querySelectorAll(".field")).find(function (field) {
      if (field.closest("[data-appverbo-quantity-edit-generated-v3='1']")) {
        return false;
      }

      return getFieldLabelQuantityEditPairs_v3(field) === expectedLabel;
    }) || null;
  }

  function findInputByFieldKeyQuantityEditPairs_v3(form, fieldKey, fieldMetaMap) {
    const field = findFieldWrapperByFieldKeyQuantityEditPairs_v3(form, fieldKey, fieldMetaMap);

    if (!field) {
      return null;
    }

    return field.querySelector("input, select, textarea");
  }

  //###################################################################################
  // (6) CRIAR INPUTS DOS PARES
  //###################################################################################

  function createLabelQuantityEditPairs_v3(text, required) {
    const label = document.createElement("label");
    label.textContent = text || "-";

    if (required) {
      const mark = document.createElement("span");
      mark.textContent = " *";
      label.appendChild(mark);
    }

    return label;
  }

  function createInputQuantityEditPairs_v3(rule, fieldKey, fieldMeta, index, value) {
    const fieldType = normalizeFieldTypeQuantityEditPairs_v3(fieldMeta.fieldType);
    const name = "process_quantity_field__" + rule.key + "__" + String(index) + "__" + fieldKey;
    let input = null;

    if (fieldType === "list" && Array.isArray(fieldMeta.listOptions) && fieldMeta.listOptions.length) {
      input = document.createElement("select");

      fieldMeta.listOptions.forEach(function (optionValue) {
        const option = document.createElement("option");
        option.value = String(optionValue || "").trim();
        option.textContent = String(optionValue || "").trim();
        input.appendChild(option);
      });
    }
    else if (fieldType === "flag") {
      input = document.createElement("select");

      [
        ["", ""],
        ["1", "Sim"],
        ["0", "Não"]
      ].forEach(function (pair) {
        const option = document.createElement("option");
        option.value = pair[0];
        option.textContent = pair[1];
        input.appendChild(option);
      });
    }
    else {
      input = document.createElement("input");

      if (fieldType === "date") {
        input.type = "date";
      }
      else if (fieldType === "number") {
        input.type = "number";
      }
      else if (fieldType === "email") {
        input.type = "email";
      }
      else if (fieldType === "phone") {
        input.type = "tel";
      }
      else {
        input.type = "text";
      }
    }

    input.name = name;
    input.value = fieldType === "date"
      ? convertDisplayDateToInputDateQuantityEditPairs_v3(value)
      : String(value || "");

    input.dataset.appverboQuantityFieldKeyV3 = fieldKey;
    input.dataset.appverboQuantityRuleKeyV3 = rule.key;
    input.dataset.appverboQuantityIndexV3 = String(index);

    if (fieldMeta.isRequired) {
      input.required = true;
    }

    return input;
  }

  function createFieldQuantityEditPairs_v3(rule, fieldKey, fieldMeta, index, value) {
    const field = document.createElement("div");

    field.className = "field appverbo-quantity-edit-field-v3";
    field.setAttribute("data-appverbo-quantity-field-v3", "1");
    field.setAttribute("data-profile-field-key", "quantity_" + rule.key + "_" + String(index) + "_" + fieldKey);

    const label = createLabelQuantityEditPairs_v3(fieldMeta.label || fieldKey, fieldMeta.isRequired);
    const input = createInputQuantityEditPairs_v3(rule, fieldKey, fieldMeta, index, value);

    field.appendChild(label);
    field.appendChild(input);

    return field;
  }

  function createGroupQuantityEditPairs_v3(rule, index, itemValues, fieldMetaMap) {
    const group = document.createElement("div");

    group.className = "appverbo-quantity-edit-group-v3";
    group.setAttribute("data-appverbo-quantity-edit-generated-v3", "1");
    group.setAttribute("data-appverbo-quantity-rule-key-v3", rule.key);
    group.setAttribute("data-appverbo-quantity-index-v3", String(index));
    group.style.gridColumn = "1 / -1";
    group.style.order = String(5000 + index);

    const title = document.createElement("div");
    title.className = "appverbo-quantity-edit-title-v3";
    title.textContent = rule.itemLabel + " " + String(index + 1);
    group.appendChild(title);

    const innerGrid = document.createElement("div");
    innerGrid.className = "appverbo-quantity-edit-grid-v3";
    group.appendChild(innerGrid);

    rule.repeatedFieldKeys.forEach(function (fieldKey) {
      const fieldMeta = fieldMetaMap.get(fieldKey) || {
        key: fieldKey,
        label: toSentenceCaseQuantityEditPairs_v3(fieldKey),
        fieldType: "text",
        isRequired: false,
        listOptions: []
      };

      const fieldElement = createFieldQuantityEditPairs_v3(
        rule,
        fieldKey,
        fieldMeta,
        index,
        itemValues ? itemValues[fieldKey] : ""
      );

      innerGrid.appendChild(fieldElement);
    });

    return group;
  }

  //###################################################################################
  // (7) PAYLOAD OCULTO
  //###################################################################################

  function collectRulePayloadQuantityEditPairs_v3(form, rule) {
    const payload = [];
    const generatedInputs = Array.from(
      form.querySelectorAll(
        '[data-appverbo-quantity-rule-key-v3="' + rule.key + '"] input, ' +
        '[data-appverbo-quantity-rule-key-v3="' + rule.key + '"] select, ' +
        '[data-appverbo-quantity-rule-key-v3="' + rule.key + '"] textarea'
      )
    );

    generatedInputs.forEach(function (input) {
      const index = Number.parseInt(String(input.dataset.appverboQuantityIndexV3 || "0"), 10);
      const fieldKey = normalizeKeyQuantityEditPairs_v3(input.dataset.appverboQuantityFieldKeyV3 || "");

      if (!Number.isFinite(index) || !fieldKey) {
        return;
      }

      if (!payload[index]) {
        payload[index] = {};
      }

      payload[index][fieldKey] = String(input.value || "").trim();
    });

    return payload.filter(function (item) {
      return item && Object.keys(item).some(function (key) {
        return String(item[key] || "").trim();
      });
    });
  }

  function syncHiddenPayloadQuantityEditPairs_v3(form, rule) {
    if (!form || !rule) {
      return;
    }

    const payloadName = "process_quantity_payload__" + rule.key;

    Array.from(form.querySelectorAll('[name="' + payloadName + '"]')).forEach(function (input) {
      input.remove();
    });

    if (!shouldRenderRuleInCurrentSectionQuantityEditPairs_v3(rule)) {
      return;
    }

    const hiddenInput = document.createElement("input");
    hiddenInput.type = "hidden";
    hiddenInput.name = payloadName;
    hiddenInput.value = JSON.stringify(collectRulePayloadQuantityEditPairs_v3(form, rule));

    form.appendChild(hiddenInput);
  }

  function bindPayloadSyncQuantityEditPairs_v3(form, rule) {
    const bindKey = "appverboQuantityPayloadBoundV3_" + rule.key;

    if (form.dataset[bindKey] === "1") {
      return;
    }

    form.dataset[bindKey] = "1";

    form.addEventListener("input", function (event) {
      const target = event.target;

      if (!target || !target.dataset || target.dataset.appverboQuantityRuleKeyV3 !== rule.key) {
        return;
      }

      syncHiddenPayloadQuantityEditPairs_v3(form, rule);
    }, true);

    form.addEventListener("change", function (event) {
      const target = event.target;

      if (!target || !target.dataset || target.dataset.appverboQuantityRuleKeyV3 !== rule.key) {
        return;
      }

      syncHiddenPayloadQuantityEditPairs_v3(form, rule);
    }, true);

    form.addEventListener("submit", function () {
      syncHiddenPayloadQuantityEditPairs_v3(form, rule);
    }, true);
  }

  //###################################################################################
  // (8) RENDER CONTROLADO POR ABA
  //###################################################################################

  function removeGeneratedPairsQuantityEditPairs_v3(form, ruleKey) {
    if (!form) {
      return;
    }

    Array.from(
      form.querySelectorAll(
        '[data-appverbo-quantity-edit-generated-v1="1"][data-appverbo-quantity-rule-key-v1="' + ruleKey + '"], ' +
        '[data-appverbo-quantity-edit-generated-v2="1"][data-appverbo-quantity-rule-key-v2="' + ruleKey + '"], ' +
        '[data-appverbo-quantity-edit-generated-v3="1"][data-appverbo-quantity-rule-key-v3="' + ruleKey + '"]'
      )
    ).forEach(function (element) {
      element.remove();
    });

    Array.from(
      form.querySelectorAll('[name="process_quantity_payload__' + ruleKey + '"]')
    ).forEach(function (input) {
      input.remove();
    });
  }

  function getQuantityCountQuantityEditPairs_v3(quantityInput, rule) {
    const parsed = Number.parseInt(String(quantityInput ? quantityInput.value : "").trim(), 10);

    if (!Number.isFinite(parsed) || parsed <= 0) {
      return 0;
    }

    return Math.min(parsed, rule.maxItems || 50);
  }

  function buildRenderSignatureQuantityEditPairs_v3(rule, quantityCount, savedValues, currentSection) {
    return JSON.stringify({
      ruleKey: rule.key,
      quantityCount: quantityCount,
      repeatedFieldKeys: rule.repeatedFieldKeys,
      savedValues: savedValues,
      currentSection: currentSection
    });
  }

  function renderRulePairsQuantityEditPairs_v3(form, grid, rule, fieldMetaMap, forceRender) {
    if (!shouldRenderRuleInCurrentSectionQuantityEditPairs_v3(rule)) {
      renderStateByRuleKey.delete(rule.key);
      removeGeneratedPairsQuantityEditPairs_v3(form, rule.key);
      return;
    }

    const quantityInput = findInputByFieldKeyQuantityEditPairs_v3(form, rule.quantityFieldKey, fieldMetaMap);
    const quantityWrapper = quantityInput ? quantityInput.closest(".field") : null;

    if (!quantityInput || !quantityWrapper || !grid) {
      return;
    }

    const quantityCount = getQuantityCountQuantityEditPairs_v3(quantityInput, rule);
    const savedValues = getQuantityValuesQuantityEditPairs_v3(rule.key);
    const currentSection = getCurrentProfileSectionQuantityEditPairs_v3();
    const signature = buildRenderSignatureQuantityEditPairs_v3(rule, quantityCount, savedValues, currentSection);

    if (!forceRender && renderStateByRuleKey.get(rule.key) === signature) {
      syncHiddenPayloadQuantityEditPairs_v3(form, rule);
      return;
    }

    renderStateByRuleKey.set(rule.key, signature);
    removeGeneratedPairsQuantityEditPairs_v3(form, rule.key);

    let insertionPoint = quantityWrapper;

    for (let index = 0; index < quantityCount; index += 1) {
      const group = createGroupQuantityEditPairs_v3(
        rule,
        index,
        savedValues[index] || {},
        fieldMetaMap
      );

      insertionPoint.insertAdjacentElement("afterend", group);
      insertionPoint = group;
    }

    syncHiddenPayloadQuantityEditPairs_v3(form, rule);
    bindPayloadSyncQuantityEditPairs_v3(form, rule);
  }

  function renderAllPairsQuantityEditPairs_v3(forceRender) {
    const form = getEditFormQuantityEditPairs_v3();
    const grid = getEditGridQuantityEditPairs_v3(form);
    const setting = getMeuPerfilSettingQuantityEditPairs_v3();

    if (!form || !grid || !setting || !isEditFormVisibleQuantityEditPairs_v3(form)) {
      return;
    }

    const fieldMetaMap = getFieldMetaMapQuantityEditPairs_v3(setting);
    const rules = normalizeQuantityRulesQuantityEditPairs_v3(setting.process_quantity_fields);

    rules.forEach(function (rule) {
      renderRulePairsQuantityEditPairs_v3(form, grid, rule, fieldMetaMap, Boolean(forceRender));
    });
  }

  //###################################################################################
  // (9) BIND DO CAMPO QUANTIDADE
  //###################################################################################

  function bindQuantityInputsQuantityEditPairs_v3() {
    const form = getEditFormQuantityEditPairs_v3();
    const setting = getMeuPerfilSettingQuantityEditPairs_v3();

    if (!form || !setting || form.dataset.appverboQuantityEditPairsBoundV3 === "1") {
      return;
    }

    const fieldMetaMap = getFieldMetaMapQuantityEditPairs_v3(setting);
    const rules = normalizeQuantityRulesQuantityEditPairs_v3(setting.process_quantity_fields);

    rules.forEach(function (rule) {
      const quantityInput = findInputByFieldKeyQuantityEditPairs_v3(form, rule.quantityFieldKey, fieldMetaMap);

      if (!quantityInput) {
        return;
      }

      quantityInput.addEventListener("input", function () {
        renderStateByRuleKey.delete(rule.key);
        window.setTimeout(function () {
          renderAllPairsQuantityEditPairs_v3(true);
        }, 0);
      });

      quantityInput.addEventListener("change", function () {
        renderStateByRuleKey.delete(rule.key);
        window.setTimeout(function () {
          renderAllPairsQuantityEditPairs_v3(true);
        }, 0);
      });
    });

    form.dataset.appverboQuantityEditPairsBoundV3 = "1";
  }

  //###################################################################################
  // (10) ESTILO
  //###################################################################################

  function installStyleQuantityEditPairs_v3() {
    if (document.getElementById("appverbo-profile-quantity-edit-pairs-style-v3")) {
      return;
    }

    const style = document.createElement("style");
    style.id = "appverbo-profile-quantity-edit-pairs-style-v3";
    style.textContent = [
      ".appverbo-quantity-edit-group-v3 { width: 100%; margin-top: 14px; }",
      ".appverbo-quantity-edit-title-v3 { margin: 0 0 10px; font-size: 14px; font-weight: 800; color: #0f172a; }",
      ".appverbo-quantity-edit-grid-v3 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px 16px; }",
      ".appverbo-quantity-edit-grid-v3 .field { min-height: 54px; }",
      ".appverbo-quantity-edit-grid-v3 .field input, .appverbo-quantity-edit-grid-v3 .field select, .appverbo-quantity-edit-grid-v3 .field textarea { width: 100%; }",
      "@media (max-width: 900px) { .appverbo-quantity-edit-grid-v3 { grid-template-columns: 1fr; } }"
    ].join("\n");

    document.head.appendChild(style);
  }

  //###################################################################################
  // (11) INICIAR
  //###################################################################################

  function startQuantityEditPairs_v3(forceRender) {
    installStyleQuantityEditPairs_v3();
    bindQuantityInputsQuantityEditPairs_v3();
    renderAllPairsQuantityEditPairs_v3(Boolean(forceRender));
  }

  document.addEventListener("click", function (event) {
    const clickedElement = event.target && event.target.closest
      ? event.target.closest("button, a, [role='tab'], [data-edit-target='perfil-pessoal-card'], .profile-edit-toggle")
      : null;

    if (!clickedElement) {
      return;
    }

    const text = normalizeTextQuantityEditPairs_v3(clickedElement.textContent || "");
    const isRelevantClick = text.includes("dados pessoais") ||
      text.includes("dados de agregados") ||
      clickedElement.matches("[data-edit-target='perfil-pessoal-card'], .profile-edit-toggle");

    if (!isRelevantClick) {
      return;
    }

    renderStateByRuleKey.clear();

    window.setTimeout(function () {
      startQuantityEditPairs_v3(true);
    }, 80);

    window.setTimeout(function () {
      startQuantityEditPairs_v3(true);
    }, 250);
  }, true);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", function () {
      startQuantityEditPairs_v3(false);
    });
  }
  else {
    startQuantityEditPairs_v3(false);
  }

  window.addEventListener("pageshow", function () {
    startQuantityEditPairs_v3(false);
  });
})();
// APPVERBO_PROFILE_QUANTITY_EDIT_PAIRS_V3_END
